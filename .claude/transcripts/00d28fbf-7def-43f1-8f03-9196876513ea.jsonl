家族尊严并立下三年之约。\", \"软弱回应会让萧家声望受损。\", 3, \"reputation>=5\", \"flag:three_year_pact=1,rel:npc_nalan_yanran:-10\", [\n93\t        (\"应对退婚\", \"在大厅冲突中维护萧家尊严。\", \"reputation>=5\", \"rel:npc_xiao_zhan:+5\"),\n94\t        (\"立下三年之约\", \"公开承担未来决战的责任。\", \"level>=3\", \"flag:three_year_pact=1,reputation:+5\"),\n95\t    ]),\n96\t    _story_phase(\"ring_awakening\", \"戒中导师\", \"退婚风波后，戒中的神秘灵魂终于现身。\", \"建立师徒关系并获得成长道路。\", \"无法取得信任会失去关键指导。\", 3, \"soul>=6,flag:three_year_pact=1\", \"flag:ring_awakened=1,rel:npc_yao_lao:+10,douqi:+5\", [\n97\t        (\"药老现身\", \"确认斗气流失的真正原因。\", \"soul>=6\", \"flag:ring_awakened=1\"),\n98\t        (\"学习炼药与焚决\", \"建立师徒信任并选择成长路线。\", \"adventure_points>=3\", \"rel:npc_yao_lao:+10,alchemy:+3\"),\n99\t    ]),\n100\t    _story_phase(\"wutan_growth\", \"乌坦城成长\", \"离开家族前，你需要功法、资金与实战经验。\", \"解决坊市冲突并完成离家准备。\", \"基础不足会使后续历练举步维艰。\", 4, \"level>=4\", \"flag:left_wutan=1,reputation:+5\", [\n101\t        (\"经营坊市资源\", \"通过炼药、交易或探索筹集资源。\", \"silver>=20\", \"alchemy:+2\"),\n102\t        (\"解决家族冲突\", \"保护萧家利益并赢得成人认可。\", \"training_wins>=2\", \"reputation:+5\"),\n103\t        (\"告别家族\", \"准备独自踏上历练之路。\", \"adventure_points>=5\", \"flag:left_wutan=1\"),\n104\t    ]),\n105\t    _story_phase(\"mountain_training\", \"魔兽山脉历练\", \"魔兽山脉中有药材、强敌与新的伙伴。\", \"完成独立生存训练并穿越山脉。\", \"缺乏实战会无法深入沙漠。\", 5, \"level>=6,flag:left_wutan=1\", \"rel:npc_xiao_yixian:+10,exp:+50\", [\n106\t        (\"青山镇立足\", \"建立补给点并了解山脉情报。\", \"adventure_points>=6\", \"reputation:+3\"),\n107\t        (\"结识小医仙\", \"共同探索遗迹并建立信任。\", \"reputation>=10\", \"rel:npc_xiao_yixian:+10\"),\n108\t        (\"面对厄难毒体\", \"帮助伙伴控制危险体质。\", \"rel:npc_xiao_yixian>=35\", \"flag:poison_companion=1\"),\n109\t    ]),\n110\t    _story_phase(\"desert_flame\", \"塔戈尔沙漠与青莲地心火\", \"异火线索指向蛇人族领地。\", \"深入沙漠并夺取青莲地心火。\", \"异火争夺失败会严重拖慢成长。\", 6, \"level>=10\", \"item:+item_green_lotus_flame,rel:npc_cai_lin:+15,douqi:+20\", [\n111\t        (\"保护青鳞\", \"解决石漠城危机并保护青鳞。\", \"reputation>=10\", \"rel:npc_qing_lin:+10\"),\n112\t        (\"寻找青莲地心火\", \"追踪地穴中的异火线索。\", \"soul>=12\", \"flag:green_lotus_found=1\"),\n113\t        (\"美杜莎神殿争夺\", \"在多方冲突中取得异火并保留转圜余地。\", \"level>=10,rel:npc_cai_lin>=-40\", \"rel:npc_cai_lin:+10\"),\n114\t    ]),\n115\t    _story_phase(\"alchemy_conference\", \"炼药师大会\", \"返回加玛帝国后，炼药师大会成为积累声望的关键机会。\", \"通过考核、解决丹王势力威胁并夺得大会认可。\", \"失败会失去帝都盟友与公开声望。\", 7, \"alchemy>=12,soul>=12\", \"reputation:+10,alchemy:+5,item:+item_elixir\", [\n116\t        (\"取得炼药师资格\", \"通过公会测试并获得参赛身份。\", \"alchemy>=10\", \"reputation:+3\"),\n117\t        (\"处理纳兰家烙毒\", \"以异火与炼药能力换取关键人脉。\", \"soul>=12\", \"reputation:+4\"),\n118\t        (\"赢得炼药师大会\", \"在大会决赛中挫败敌对炼药师。\", \"alchemy>=12\", \"alchemy:+5,reputation:+8\"),\n119\t    ]),\n120\t    _story_phase(\"yunlan_duel\", \"三年之约决战\", \"约定期限已至，你必须登上云岚宗。\", \"击败纳兰嫣然并从宗门追击中脱身。\", \"失败会让三年努力失去意义。\", 8, \"level>=15,flag:three_year_pact=1\", \"flag:rival_resolved=1,flag:yunlan_hostile=1,reputation:+20\", [\n121\t        (\"登上云岚宗\", \"突破宗门压力并抵达决战场。\", \"level>=15\", \"reputation:+5\"),\n122\t        (\"击败纳兰嫣然\", \"兑现三年之约。\", \"flag:three_year_pact=1\", \"rel:npc_nalan_yanran:+20,reputation:+10\"),\n123\t        (\"再上云岚宗击杀云棱\", \"处理萧家遇袭的直接责任人。\", \"reputation>=20\", \"flag:yunleng_defeated=1\"),\n124\t        (\"逃离加玛帝国\", \"在云山追击下保全自己并前往黑角域。\", \"soul>=15\", \"flag:first_yunlan_escape=1\"),\n125\t    ]),\n126\t    _story_phase(\"canaan_outer\", \"迦南学院外院\", \"离开加玛帝国后，你终于前往迦南学院。\", \"完成入院与外院成长，为进入内院做准备。\", \"无法进入内院会错失核心修炼资源。\", 9, \"level>=18\", \"flag:joined_canaan=1,reputation:+8\", [\n127\t        (\"穿越黑角域\", \"通过黑域大平原与拍卖争夺抵达学院。\", \"adventure_points>=10,flag:first_yunlan_escape=1\", \"flag:first_black_corner_crossing=1\"),\n128\t        (\"抵达迦南学院\", \"完成迟到后的入院考验。\", \"level>=18\", \"flag:joined_canaan=1\"),\n129\t        (\"建立新生队伍\", \"与同伴形成可靠的小队。\", \"reputation>=25\", \"reputation:+5\"),\n130\t        (\"通过内院选拔赛\", \"赢得进入内院的资格。\", \"training_wins>=3\", \"flag:entered_inner_academy=1\"),\n131\t    ]),\n132\t    _story_phase(\"canaan_inner\", \"内院磐门与强榜\", \"内院资源竞争激烈，新生必须抱团立足。\", \"建立磐门并在强榜大赛中取得资格。\", \"没有自己的势力将持续受到压制。\", 10, \"flag:entered_inner_academy=1,reputation>=25\", \"flag:pan_gate_founded=1,reputation:+10\", [\n133\t        (\"建立磐门\", \"团结新生并建立稳定据点。\", \"reputation>=25\", \"flag:pan_gate_founded=1\"),\n134\t        (\"结识紫研\", \"通过内院任务与紫研建立信任。\", \"adventure_points>=12\", \"rel:npc_ziyan:+10\"),\n135\t        (\"挑战强榜大赛\", \"取得进入天焚炼气塔核心区域的资格。\", \"training_wins>=4\", \"flag:strong_rank_won=1\"),\n136\t    ]),\n137\t    _story_phase(\"fallen_heart\", \"陨落心炎与天焚炼气塔\", \"天焚炼气塔异动，陨落心炎即将失控。\", \"守住内院并收服陨落心炎。\", \"异火失控会摧毁内院。\", 11, \"level>=25,flag:strong_rank_won=1\", \"item:+item_fallen_heart_flame,douqi:+30\", [\n138\t        (\"调查炼气塔异动\", \"确认陨落心炎暴动征兆。\", \"soul>=20\", \"flag:fallen_heart_unstable=1\"),\n139\t        (\"深入塔底\", \"在封印崩溃前抵达异火本体。\", \"level>=25\", \"exp:+80\"),\n140\t        (\"收服陨落心炎\", \"承受异火炼体并返回内院。\", \"flag:fallen_heart_unstable=1\", \"item:+item_fallen_heart_flame\"),\n141\t    ]),\n142\t    _story_phase(\"black_corner_war\", \"黑角域入侵内院\", \"韩枫联合黑角域势力进攻内院，试图夺走陨落心炎。\", \"守住内院并击退韩枫与黑盟。\", \"学院失守会让异火和盟友落入韩枫手中。\", 12, \"level>=28,flag:pan_gate_founded=1\", \"flag:han_feng_escaped=1,flag:soul_hall_exposed=1,reputation:+15\", [\n143\t        (\"集结学院盟友\", \"组织内院力量抵挡黑盟入侵。\", \"reputation>=35\", \"reputation:+5\"),\n144\t        (\"击退韩枫与黑盟\", \"保住学院并摧毁韩枫肉身。\", \"level>=28\", \"flag:han_feng_hostile=1\"),\n145\t        (\"发现魂殿接应\", \"确认韩枫灵魂被魂殿救走。\", \"soul>=25\", \"flag:han_feng_escaped=1,flag:soul_hall_exposed=1\"),\n146\t    ]),\n147\t    _story_phase(\"yunlan_war\", \"重返加玛与云岚宗大战\", \"父亲失踪、萧家遭难，线索指向云岚宗与魂殿。\", \"救援萧家、击败云山并重建故土秩序。\", \"拖延会让萧家与盟友被逐个击破。\", 13, \"level>=30,flag:first_yunlan_escape=1\", \"flag:yan_alliance_founded=1,reputation:+20\", [\n148\t        (\"追查父亲失踪\", \"确认萧家危机与魂殿介入。\", \"reputation>=35\", \"flag:xiao_family_crisis=1\"),\n149\t        (\"击败云山，药老被掳\", \"终结云岚宗威胁，但魂殿护法趁乱掳走药老。\", \"level>=30,flag:yunlan_hostile=1\", \"flag:yunlan_defeated=1,flag:yao_lao_captured=1\"),\n150\t        (\"建立炎盟\", \"联合加玛帝国盟友保护萧家。\", \"reputation>=45\", \"flag:yan_alliance_founded=1\"),\n151\t    ]),\n152\t    _story_phase(\"poison_sect_war\", \"出云帝国与毒宗之战\", \"炎盟刚刚建立，毒宗、金雁宗与慕兰谷便入侵加玛帝国。\", \"守住炎盟、重逢小医仙并解决厄难毒体危机。\", \"联盟初战失败会让故土再次陷入战乱。\", 14, \"level>=33,flag:yan_alliance_founded=1\", \"flag:northwest_stabilized=1,rel:npc_xiao_yixian:+15,reputation:+15\", [\n153\t        (\"守卫加玛帝国\", \"带领炎盟击退三宗联军。\", \"reputation>=50\", \"flag:yan_alliance_defended=1\"),\n154\t        (\"重逢毒宗宗主\", \"确认小医仙身份并避免双方死战。\", \"rel:npc_xiao_yixian>=40\", \"rel:npc_xiao_yixian:+10\"),\n155\t        (\"暂时封印厄难毒体\", \"寻找毒丹之法，暂时压制小医仙的毒体。\", \"alchemy>=20,flag:poison_companion=1\", \"flag:poison_body_sealed=1\"),\n156\t    ]),\n157\t    _story_phase(\"return_black_corner\", \"重返黑角域\", \"魂殿线索与韩枫逃亡方向都指向黑角域。\", \"清算魔炎谷、擒获韩枫并取得魂殿情报。\", \"缺少情报便无法定位药老。\", 15, \"level>=35,flag:han_feng_escaped=1\", \"flag:han_feng_captured=1,flag:mentor_prison_known=1,reputation:+15\", [\n158\t        (\"清算魔炎谷\", \"摧毁黑角域中敌对势力的核心据点。\", \"reputation>=55\", \"flag:demon_flame_valley_defeated=1\"),\n159\t        (\"擒获韩枫灵魂\", \"击败韩枫与魂殿接应者。\", \"level>=35,flag:han_feng_escaped=1\", \"flag:han_feng_captured=1\"),\n160\t        (\"取得药老关押情报\", \"从韩枫与魂殿护法处取得关键线索。\", \"soul>=30\", \"flag:mentor_prison_known=1\"),\n161\t    ]),\n162\t    _story_phase(\"revisit_tower\", \"再探天焚炼气塔\", \"黑角域清算后，炼气塔底的岩浆世界仍隐藏着异火和古帝线索。\", \"再入塔底、救出天火尊者并发现古帝洞府线索。\", \"忽略塔底秘密会让终局线索断裂。\", 16, \"level>=36,flag:han_feng_captured=1\", \"flag:ancient_emperor_clue_found=1,reputation:+8\", [\n163\t        (\"返回迦南学院\", \"安置萧门与磐门并准备再入塔底。\", \"reputation>=58\", \"reputation:+3\"),\n164\t        (\"救出天火尊者\", \"深入岩浆世界并帮助残魂脱困。\", \"soul>=32\", \"flag:tianhuo_rescued=1\"),\n165\t        (\"发现古帝玉线索\", \"确认岩浆世界与古帝洞府存在联系。\", \"flag:tianhuo_rescued=1\", \"flag:ancient_emperor_clue_found=1\"),\n166\t    ]),\n167\t    _story_phase(\"zhongzhou_arrival\", \"进入中州\", \"药老被魂殿掳走，新的线索指向强者云集的中州。\", \"在中州立足、寻找星陨阁并追查魂殿。\", \"没有据点与情报便无法展开营救。\", 16, \"level>=36,flag:mentor_prison_known=1\", \"flag:star_pavilion_found=1,reputation:+15\", [\n168\t        (\"穿越空间虫洞\", \"抵达中州并适应新的强敌环境。\", \"level>=35\", \"exp:+100\"),\n169\t        (\"四方阁立威\", \"通过风雷阁冲突建立中州声望。\", \"training_wins>=5\", \"reputation:+10\"),\n170\t        (\"找到风尊者与星陨阁\", \"联系药老旧友并建立营救据点。\", \"reputation>=50\", \"flag:star_pavilion_found=1,rel:npc_feng_zunzhe:+15\"),\n171\t    ]),\n172\t    _story_phase(\"ye_ice_valley\", \"叶城与冰河谷\", \"中州丹塔选拔将近，小医仙的厄难毒体也引来冰河谷追杀。\", \"帮助叶家取得资格，并彻底解决厄难毒体。\", \"毒体失控会危及小医仙与周围所有人。\", 17, \"level>=38,flag:poison_body_sealed=1\", \"flag:poison_body_resolved=1,reputation:+12\", [\n173\t        (\"帮助叶家通过考核\", \"取得参加丹会的正式资格。\", \"alchemy>=28\", \"flag:dan_meeting_qualified=1\"),\n174\t        (\"迎战冰河谷\", \"保护小医仙并击退冰河谷追兵。\", \"level>=38,rel:npc_xiao_yixian>=50\", \"reputation:+5\"),\n175\t        (\"凝聚毒丹\", \"彻底控制厄难毒体而非继续封印。\", \"alchemy>=30,flag:poison_body_sealed=1\", \"flag:poison_body_resolved=1\"),\n176\t    ]),\n177\t    _story_phase(\"dan_meeting_flame\", \"丹会与三千焱炎火\", \"丹塔大会能提供声望、盟友与接近三千焱炎火的机会。\", \"赢得丹会并收服星域异火。\", \"失败会失去营救药老的重要支援。\", 18, \"level>=40,alchemy>=30,soul>=30,flag:dan_meeting_qualified=1\", \"item:+item_three_thousand_flame,alchemy:+15,reputation:+20\", [\n178\t        (\"通过丹会选拔\", \"证明炼药与灵魂能力。\", \"alchemy>=30,soul>=30\", \"reputation:+10\"),\n179\t        (\"赢得丹会\", \"在顶尖炼药师竞争中夺得名次。\", \"alchemy>=35\", \"flag:dan_meeting_won=1\"),\n180\t        (\"进入星域收服异火\", \"处理魂殿干扰并取得三千焱炎火。\", \"level>=40,flag:dan_meeting_won=1\", \"item:+item_three_thousand_flame\"),\n181\t    ]),\n182\t    _story_phase(\"save_mentor\", \"营救药老\", \"魂殿囚禁着药老，营救时机终于成熟。\", \"突袭亡魂山脉并救回药老灵魂。\", \"失败将失去导师和对抗魂殿的核心盟友。\", 19, \"level>=45,flag:star_pavilion_found=1,rel:npc_yao_lao>=60\", \"flag:yao_lao_rescued=1,rel:npc_yao_lao:+20,reputation:+20\", [\n183\t        (\"突袭魂殿分殿\", \"依靠丹塔与星陨阁情报展开营救。\", \"reputation>=60\", \"flag:yao_lao_rescued=1\"),\n184\t        (\"撤回星陨阁\", \"保护重伤的药老灵魂撤离。\", \"soul>=40,flag:yao_lao_rescued=1\", \"flag:mentor_soul_secured=1\"),\n185\t        (\"准备复活材料\", \"确认重塑躯体仍缺少斗圣骸骨。\", \"alchemy>=40\", \"flag:saint_bones_needed=1\"),\n186\t    ]),\n187\t    _story_phase(\"ancient_ruins\", \"远古遗迹\", \"远古遗迹现世，其中的斗圣骸骨是复活药老的关键。\", \"探索遗迹、取得龙凰本源果与斗圣骸骨。\", \"无法取得骸骨便不能为药老重塑躯体。\", 20, \"level>=48,soul>=35,flag:saint_bones_needed=1\", \"item:+item_earth_skill,flag:saint_bones_acquired=1,soul:+10\", [\n188\t        (\"定位遗迹入口\", \"识别空间波动并准备探索队伍。\", \"soul>=35\", \"exp:+50\"),\n189\t        (\"重逢青鳞\", \"在遗迹中与青鳞会合并应对远古天蛇力量。\", \"rel:npc_qing_lin>=35\", \"rel:npc_qing_lin:+10\"),\n190\t        (\"取得龙凰本源果\", \"为紫研后续的龙皇血脉觉醒准备机缘。\", \"level>=48\", \"flag:dragon_phoenix_fruit_acquired=1\"),\n191\t        (\"夺取斗圣骸骨\", \"击退争夺者并带回重塑躯体的核心材料。\", \"reputation>=70\", \"item:+item_earth_skill,flag:saint_bones_acquired=1\"),\n192\t    ]),\n193\t    _story_phase(\"revive_mentor\", \"复活药老与重建星陨阁\", \"斗圣骸骨已经到手，可以为药老重塑躯体。\", \"复活药老并将星陨阁建设为长期据点。\", \"拖延会让魂殿再次找到虚弱的药老。\", 21, \"alchemy>=42,flag:saint_bones_acquired=1,flag:mentor_soul_secured=1\", \"flag:yao_lao_revived=1,flag:star_pavilion_rebuilt=1,reputation:+20\", [\n194\t        (\"炼制斗圣躯体\", \"使用斗圣骸骨与异火完成躯体炼制。\", \"alchemy>=42,flag:saint_bones_acquired=1\", \"flag:saint_body_refined=1\"),\n195\t        (\"药老复活\", \"让药老灵魂与新躯体完成融合。\", \"soul>=45,flag:saint_body_refined=1\", \"flag:yao_lao_revived=1,rel:npc_yao_lao:+15\"),\n196\t        (\"重建星陨阁\", \"将临时营救据点发展为长期势力。\", \"reputation>=75\", \"flag:star_pavilion_rebuilt=1\"),\n197\t    ]),\n198\t    _story_phase(\"flower_sect\", \"花宗与云韵传承\", \"花宗传承纷争将云韵卷入危机，也影响中州盟友格局。\", \"帮助云韵取得花宗传承并争取花宗支持。\", \"花宗落入敌对势力会削弱未来联盟。\", 22, \"level>=50,flag:star_pavilion_rebuilt=1\", \"flag:flower_sect_allied=1,rel:npc_yun_yun:+15,reputation:+10\", [\n199\t        (\"赶往花宗\", \"响应云韵求援并查明宗主传承争议。\", \"reputation>=75\", \"rel:npc_yun_yun:+5\"),\n200\t        (\"击败花宗敌手\", \"保护云韵完成传承。\", \"level>=50\", \"exp:+120\"),\n201\t        (\"争取花宗支持\", \"让花宗成为星陨阁的盟友。\", \"rel:npc_yun_yun>=30\", \"flag:flower_sect_allied=1\"),\n202\t    ]),\n203\t    _story_phase(\"dragon_island_legacy\", \"龙岛与龙皇血脉\", \"龙凰本源果被送往分裂的古龙岛，紫研需要完成血脉觉醒。\", \"帮助紫研觉醒龙皇血脉并稳住东龙岛。\", \"紫研失败会让太虚古龙族继续分裂。\", 23, \"level>=50,rel:npc_ziyan>=35,flag:dragon_phoenix_fruit_acquired=1\", \"flag:dragon_emperor_awakened=1,rel:npc_ziyan:+15,reputation:+10\", [\n204\t        (\"抵达东龙岛\", \"穿越虚空并确认古龙族分裂局势。\", \"soul>=40\", \"flag:east_dragon_island_reached=1\"),\n205\t        (\"守护龙凰晶层\", \"在三岛压力下保护紫研完成炼化。\", \"level>=50\", \"rel:npc_ziyan:+10\"),\n206\t        (\"见证龙皇觉醒\", \"帮助紫研继承龙皇血脉。\", \"rel:npc_ziyan>=40\", \"flag:dragon_emperor_awakened=1\"),\n207\t    ]),\n208\t    _story_phase(\"gu_clan_tomb\", \"古族成人礼与天墓\", \"古族成人礼与天墓开启提供了接触萧族先祖的机会。\", \"赢得古族认可并获得萧玄传承。\", \"失败会削弱古族联盟与血脉成长。\", 24, \"level>=52,rel:npc_xun_er>=60\", \"rel:npc_gu_yuan:+20,douqi:+50\", [\n209\t        (\"参加古族成人礼\", \"在远古种族面前证明实力。\", \"reputation>=75\", \"rel:npc_gu_yuan:+10\"),\n210\t        (\"进入天墓\", \"与同伴穿越能量风暴。\", \"level>=50\", \"exp:+150\"),\n211\t        (\"接受萧玄传承\", \"恢复萧族血脉并理解先祖使命。\", \"soul>=45\", \"flag:xiao_bloodline_awakened=1,douqi:+30\"),\n212\t    ]),\n213\t    _story_phase(\"northwest_fortress_war\", \"玄黄要塞与西北大陆大战\", \"魂殿联军进攻西北大陆，炎盟与萧家在玄黄要塞陷入苦战。\", \"返回故土、守住要塞并稳定西北联盟。\", \"故土失守会让天府联盟失去根基。\", 25, \"level>=54,flag:yan_alliance_founded=1\", \"flag:northwest_front_secured=1,reputation:+18\", [\n214\t        (\"赶回玄黄要塞\", \"响应炎盟求援并集结故土盟友。\", \"reputation>=82\", \"flag:northwest_reinforced=1\"),\n215\t        (\"守卫萧家与炎盟\", \"击退魂殿联军对西北大陆的进攻。\", \"level>=54\", \"reputation:+10\"),\n216\t        (\"稳定西北战线\", \"重新整合加玛、出云与蛇人族力量。\", \"flag:northwest_stabilized=1\", \"flag:northwest_front_secured=1\"),\n217\t    ]),\n218\t    _story_phase(\"bodhi_tree\", \"莽荒古域与菩提古树\", \"菩提古树现世，进入莽荒古域还需面对兽潮与各方争夺。\", \"穿越莽荒古域、突破幻境并取得菩提心。\", \"心境不足会永远迷失。\", 25, \"level>=55,soul>=45\", \"item:+item_bodhi_heart,item:+item_bodhi_seed,soul:+20\", [\n219\t        (\"穿越莽荒古域兽潮\", \"与盟友突破古域入口和兽潮阻拦。\", \"reputation>=80\", \"exp:+100\"),\n220\t        (\"争夺古树入口\", \"与各方势力竞争进入资格。\", \"reputation>=80\", \"exp:+100\"),\n221\t        (\"突破菩提幻境\", \"分辨幻象并保持自我。\", \"soul>=45\", \"soul:+10\"),\n222\t        (\"取得菩提心\", \"吸收古树核心机缘并完成境界突破。\", \"level>=55\", \"item:+item_bodhi_heart,item:+item_bodhi_seed\"),\n223\t    ]),\n224\t    _story_phase(\"tianfu_alliance\", \"建立天府联盟\", \"魂殿全面施压，单一势力已无法抵抗。\", \"联合星陨阁、丹塔、炎盟与伙伴势力。\", \"联盟失败会让各方被逐个击破。\", 26, \"flag:star_pavilion_rebuilt=1,flag:yan_alliance_founded=1,reputation>=90\", \"flag:tianfu_alliance_founded=1,reputation:+20\", [\n225\t        (\"调查灵族消失\", \"确认远古种族正在遭受魂族秘密袭击。\", \"soul>=50\", \"flag:ancient_clan_disappearances=1\"),\n226\t        (\"整合星陨阁与炎盟\", \"统一两地情报与资源网络。\", \"reputation>=90\", \"reputation:+5\"),\n227\t        (\"争取丹塔与伙伴势力\", \"让中州盟友加入共同防线。\", \"alchemy>=45,rel:npc_ziyan>=35\", \"reputation:+10\"),\n228\t        (\"建立天府联盟\", \"形成能够正面对抗魂殿的联盟。\", \"flag:star_pavilion_rebuilt=1\", \"flag:tianfu_alliance_founded=1\"),\n229\t    ]),\n230\t    _story_phase(\"nether_spring\", \"九幽黄泉与妖暝\", \"建立天府联盟后，需要争取九幽地冥蟒族并强化彩鳞血脉。\", \"救出妖暝、取得妖圣精血并争取魔兽盟友。\", \"缺少魔兽盟友会让联盟侧翼空虚。\", 27, \"level>=58,flag:tianfu_alliance_founded=1\", \"flag:nether_python_allied=1,rel:npc_cai_lin:+15,reputation:+10\", [\n231\t        (\"深入九幽黄泉\", \"帮助彩鳞寻找血脉突破机缘。\", \"rel:npc_cai_lin>=20\", \"rel:npc_cai_lin:+10\"),\n232\t        (\"救出妖暝\", \"推翻九幽地冥蟒族中的篡位者。\", \"level>=58\", \"flag:yaoming_restored=1\"),\n233\t        (\"争取魔兽盟友\", \"让九幽地冥蟒族加入天府联盟。\", \"flag:yaoming_restored=1\", \"flag:nether_python_allied=1\"),\n234\t    ]),\n235\t    _story_phase(\"dragon_island_war\", \"古龙岛三岛大战\", \"三大龙王拒绝承认紫研，古龙族战争爆发。\", \"帮助紫研击败三岛联军，但北龙王趁乱逃脱。\", \"北龙王仍会成为后续隐患。\", 28, \"level>=60,flag:dragon_emperor_awakened=1\", \"flag:north_dragon_escaped=1,rel:npc_ziyan:+15,reputation:+15\", [\n236\t        (\"重返古龙岛\", \"响应紫研求援并集结东龙岛力量。\", \"rel:npc_ziyan>=45\", \"reputation:+5\"),\n237\t        (\"迎战三大龙王\", \"打破三岛联军并保护紫研。\", \"level>=60\", \"exp:+200\"),\n238\t        (\"北龙王逃脱\", \"结束三岛大战并追踪北龙王去向。\", \"flag:dragon_emperor_awakened=1\", \"flag:north_dragon_escaped=1\"),\n239\t    ]),\n240\t    _story_phase(\"soul_hall_war\", \"血洗魂殿人殿\", \"天府联盟成立后，双方开始争夺中州主动权。\", \"摧毁魂殿核心分殿并夺回灵魂本源。\", \"若魂殿仍掌握灵魂本源，联盟将持续受制。\", 29, \"level>=62,flag:tianfu_alliance_founded=1\", \"flag:soul_hall_weakened=1,soul:+15,reputation:+20\", [\n241\t        (\"血洗魂殿人殿\", \"摧毁魂殿灵魂收集据点。\", \"reputation>=105\", \"flag:soul_hall_core_exposed=1\"),\n242\t        (\"夺回灵魂本源\", \"释放被囚灵魂并强化自身灵魂境界。\", \"soul>=55,flag:soul_hall_core_exposed=1\", \"soul:+15\"),\n243\t        (\"逼退魂殿殿主\", \"迫使魂殿收缩，但殿主仍未被彻底击败。\", \"level>=62\", \"flag:soul_hall_weakened=1\"),\n244\t    ]),\n245\t    _story_phase(\"demon_flame\", \"净莲妖火\", \"残图汇聚，净莲妖火空间开启。\", \"突破妖火幻境并完成收服。\", \"失败会被妖火控制。\", 30, \"level>=64,soul>=55,flag:soul_hall_weakened=1\", \"item:+item_purifying_demon_flame,douqi:+80\", [\n246\t        (\"集齐妖火残图\", \"借助联盟情报定位妖火空间。\", \"soul>=50\", \"flag:demon_flame_map=1\"),\n247\t        (\"突破妖火幻境\", \"抵抗净莲妖圣留下的幻境。\", \"soul>=55\", \"soul:+10\"),\n248\t        (\"收服净莲妖火\", \"与盟友共同压制妖火本体。\", \"level>=60\", \"item:+item_purifying_demon_flame\"),\n249\t    ]),\n250\t    _story_phase(\"post_demon_wars\", \"魂殿殿主与北龙王终战\", \"净莲妖火之后，魂殿殿主与逃亡的北龙王先后发动反扑。\", \"击败两名强敌并完成古龙族统一。\", \"残余强敌会破坏大陆联盟。\", 31, \"level>=66,flag:north_dragon_escaped=1,flag:soul_hall_weakened=1\", \"flag:soul_hall_defeated=1,flag:dragon_clan_unified=1,reputation:+20\", [\n251\t        (\"击败魂殿殿主\", \"终结魂殿在中州的公开统治。\", \"level>=66,flag:soul_hall_weakened=1\", \"flag:soul_hall_defeated=1\"),\n252\t        (\"追击北龙王\", \"阻止北龙王利用化龙魔阵反扑。\", \"rel:npc_ziyan>=50,flag:north_dragon_escaped=1\", \"exp:+200\"),\n253\t        (\"统一太虚古龙族\", \"彻底结束古龙族分裂。\", \"flag:north_dragon_escaped=1\", \"flag:dragon_clan_unified=1\"),\n254\t    ]),\n255\t    _story_phase(\"medicine_ceremony\", \"药典与药族灭族战\", \"药族举办药典，魂族随后发动灭族袭击。\", \"通过药典、救援药族幸存者并确认魂族计划。\", \"药族覆灭会让魂族夺得更多血脉与帝玉。\", 32, \"alchemy>=50,soul>=55\", \"alchemy:+20,flag:medicine_clan_survivors_saved=1,reputation:+20\", [\n256\t        (\"完成药典考验\", \"展现高阶炼药与灵魂控制。\", \"alchemy>=50,soul>=55\", \"alchemy:+10\"),\n257\t        (\"应对药族灭族战\", \"在魂族袭击中保护药族幸存者。\", \"level>=65\", \"flag:hun_clan_hostile=1\"),\n258\t        (\"救出药族幸存者\", \"将幸存力量带回联盟并保存药族传承。\", \"reputation>=110\", \"flag:medicine_clan_survivors_saved=1\"),\n259\t    ]),\n260\t    _story_phase(\"ancient_clan_war\", \"远古种族联盟战\", \"魂族开始夺取各族帝玉，远古种族面临覆灭。\", \"协调古族、古龙族与盟友，并救回被囚的父亲。\", \"联盟破裂会让魂族打开古帝洞府。\", 33, \"flag:dragon_clan_unified=1,flag:hun_clan_hostile=1\", \"flag:ancient_alliance=1,rel:npc_xiao_zhan:+20,reputation:+25\", [\n261\t        (\"确认魂族夺玉计划\", \"整合药族幸存者与古族情报。\", \"flag:medicine_clan_survivors_saved=1\", \"flag:emperor_jade_crisis=1\"),\n262\t        (\"再入天墓\", \"借助萧玄残魂将灵魂境界提升至帝境。\", \"flag:xiao_bloodline_awakened=1,soul>=65\", \"flag:emperor_soul_awakened=1,soul:+20\"),\n263\t        (\"营救萧战\", \"在魂族大战中救回被囚多年的父亲。\", \"flag:xiao_family_crisis=1,level>=68\", \"flag:xiao_zhan_rescued=1,rel:npc_xiao_zhan:+20\"),\n264\t        (\"协调远古种族盟友\", \"争取古族与统一后的太虚古龙族共同作战。\", \"rel:npc_gu_yuan>=30,flag:dragon_clan_unified=1\", \"flag:ancient_alliance=1\"),\n265\t    ]),\n266\t    _story_phase(\"ancient_emperor\", \"古帝洞府\", \"魂族打开古帝洞府，成帝传承成为最后争夺。\", \"进入洞府并阻止魂族独占传承。\", \"失败会让魂天帝完成最终突破。\", 34, \"level>=70,flag:ancient_alliance=1\", \"flag:ancient_emperor_jade=1,item:+item_tuoshe_jade,douqi:+100\", [\n267\t        (\"追入古帝洞府\", \"集结联盟进入洞府空间。\", \"flag:ancient_alliance=1\", \"flag:ancient_emperor_jade=1\"),\n268\t        (\"争夺帝品雏丹\", \"阻止魂族夺取成帝关键。\", \"level>=70\", \"douqi:+50\"),\n269\t        (\"魂天帝夺丹成帝\", \"在争夺失败后应对魂天帝完成突破的危机。\", \"level>=72\", \"flag:soul_emperor_ascended=1\"),\n270\t        (\"接受古帝传承\", \"获得迎战魂天帝的最后力量。\", \"flag:emperor_soul_awakened=1\", \"flag:emperor_legacy=1,douqi:+100\"),\n271\t    ]),\n272\t    _story_phase(\"final_war\", \"双帝之战\", \"魂天帝突破，大陆已无退路。\", \"集结联军并完成最终决战。\", \"失败意味着大陆秩序覆灭。\", 35, \"level>=80,flag:emperor_legacy=1\", \"flag:soul_emperor_defeated=1,reputation:+100\", [\n273\t        (\"集结大陆联军\", \"让所有盟友进入最终战场。\", \"reputation>=120,flag:ancient_alliance=1\", \"reputation:+20\"),\n274\t        (\"突破斗帝\", \"以古帝传承与异火完成最终突破。\", \"level>=80,flag:emperor_legacy=1\", \"flag:xiao_emperor_awakened=1\"),\n275\t        (\"迎战魂天帝\", \"封印魂天帝并终结魂族战争。\", \"flag:xiao_emperor_awakened=1\", \"flag:soul_emperor_defeated=1\"),\n276\t    ]),\n277\t    _story_phase(\"five_emperors\", \"五帝破空\", \"大战结束后，大陆恢复秩序，新的世界通道出现。\", \"安置盟友、留下传承并开启新纪元。\", \"若没有完成战后安排，胜利仍会留下隐患。\", 36, \"flag:soul_emperor_defeated=1\", \"flag:story_finished=1,item:+item_emperor_flame\", [\n278\t        (\"重建大陆秩序\", \"处理战后势力与家族安置。\", \"reputation>=150\", \"reputation:+20\"),\n279\t        (\"留下斗帝传承\", \"让新的修炼道路延续。\", \"flag:xiao_emperor_awakened=1\", \"item:+item_emperor_flame\"),\n280\t        (\"五帝破空\", \"与重要伙伴前往新的世界。\", \"flag:ancient_alliance=1\", \"flag:story_finished=1\"),\n281\t    ]),\n282\t]\n283\t\n284\t\n285\t# 工作簿里程碑必须映射到真实节点，并按实际剧情先后排列。\n286\tPLOT_MILESTONE_SEQUENCE = [\n287\t    \"退婚\", \"三年之约\", \"青莲地心火争夺\", \"炼药师大会\", \"内院选拔赛\",\n288\t    \"强榜大赛\", \"陨落心炎与天焚炼气塔\", \"黑角域大战\", \"云岚宗大战\",\n289\t    \"丹会\", \"三千焱炎火\", \"营救药老\", \"远古遗迹\", \"古族成人礼\",\n290\t    \"天墓与萧玄\", \"菩提古树\", \"净莲妖火\", \"药典\", \"古帝洞府\",\n291\t    \"双帝之战\", \"五帝破空\",\n292\t]\n293\t\n294\tPLOT_MILESTONE_COVERAGE = {\n295\t    \"退婚\": (\"退婚与三年之约\", \"应对退婚\"),\n296\t    \"三年之约\": (\"退婚与三年之约\", \"立下三年之约\"),\n297\t    \"青莲地心火争夺\": (\"塔戈尔沙漠与青莲地心火\", \"美杜莎神殿争夺\"),\n298\t    \"炼药师大会\": (\"炼药师大会\", \"赢得炼药师大会\"),\n299\t    \"内院选拔赛\": (\"迦南学院外院\", \"通过内院选拔赛\"),\n300\t    \"强榜大赛\": (\"内院磐门与强榜\", \"挑战强榜大赛\"),\n301\t    \"陨落心炎与天焚炼气塔\": (\"陨落心炎与天焚炼气塔\", \"收服陨落心炎\"),\n302\t    \"黑角域大战\": (\"黑角域入侵内院\", \"击退韩枫与黑盟\"),\n303\t    \"云岚宗大战\": (\"重返加玛与云岚宗大战\", \"击败云山，药老被掳\"),\n304\t    \"丹会\": (\"丹会与三千焱炎火\", \"赢得丹会\"),\n305\t    \"三千焱炎火\": (\"丹会与三千焱炎火\", \"进入星域收服异火\"),\n306\t    \"营救药老\": (\"营救药老\", \"突袭魂殿分殿\"),\n307\t    \"远古遗迹\": (\"远古遗迹\", \"夺取斗圣骸骨\"),\n308\t    \"古族成人礼\": (\"古族成人礼与天墓\", \"参加古族成人礼\"),\n309\t    \"天墓与萧玄\": (\"古族成人礼与天墓\", \"接受萧玄传承\"),\n310\t    \"菩提古树\": (\"莽荒古域与菩提古树\", \"取得菩提心\"),\n311\t    \"净莲妖火\": (\"净莲妖火\", \"收服净莲妖火\"),\n312\t    \"药典\": (\"药典与药族灭族战\", \"完成药典考验\"),\n313\t    \"古帝洞府\": (\"古帝洞府\", \"追入古帝洞府\"),\n314\t   