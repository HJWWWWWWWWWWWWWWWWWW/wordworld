\n135\t                \"options\": options,\n136\t                \"speaker_id\": row.get(\"Speaker_ID\", \"\"),\n137\t                \"scene_npcs\": [\n138\t                    item for item in row.get(\"Scene_NPCs\", \"\").split(\",\") if item\n139\t                ],\n140\t                \"faction_context\": [\n141\t                    item for item in row.get(\"Faction_Context\", \"\").split(\",\") if item\n142\t                ],\n143\t            }\n144\t        )\n145\t    return events\n146\t\n147\t\n148\tdef _parse_attributes(rows: List[Dict[str, str]]) -> Dict[str, Dict[str, Any]]:\n149\t    return {\n150\t        row[\"Attr_ID\"]: {\n151\t            \"id\": row[\"Attr_ID\"],\n152\t            \"name\": row.get(\"Name\", row[\"Attr_ID\"]),\n153\t            \"initial\": _to_int(row.get(\"Initial\")),\n154\t            \"min\": _to_int(row.get(\"Min\"), -999999999),\n155\t            \"max\": _to_int(row.get(\"Max\"), 999999999),\n156\t        }\n157\t        for row in rows\n158\t        if row.get(\"Attr_ID\")\n159\t    }\n160\t\n161\t\n162\tdef _parse_relationships(rows: List[Dict[str, str]]) -> List[Dict[str, Any]]:\n163\t    relationships: List[Dict[str, Any]] = []\n164\t    for row in rows:\n165\t        relation_id = row.get(\"Relation_ID\", \"\")\n166\t        if not relation_id:\n167\t            continue\n168\t        relationships.append(\n169\t            {\n170\t                \"id\": relation_id,\n171\t                \"source\": row.get(\"Source_ID\", \"\"),\n172\t                \"target\": row.get(\"Target_ID\", \"\"),\n173\t                \"type\": row.get(\"Relation_Type\", \"\"),\n174\t                \"initial_value\": _to_int(row.get(\"Initial_Value\")),\n175\t                \"min_value\": _to_int(row.get(\"Min_Value\"), -100),\n176\t                \"max_value\": _to_int(row.get(\"Max_Value\"), 100),\n177\t                \"stage_rule\": row.get(\"Stage_Rule\", \"\"),\n178\t                \"bidirectional\": _to_bool(row.get(\"