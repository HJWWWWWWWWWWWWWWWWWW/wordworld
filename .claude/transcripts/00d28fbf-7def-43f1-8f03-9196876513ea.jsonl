武场检验年轻一辈。你必须证明自己没有彻底失去锋芒。\",\n575\t        \"goals\": {\"level\": 2, \"training_wins\": 1},\n576\t        \"success_text\": \"你在试炼中稳住阵脚，赢得了父亲与族人的认可。\",\n577\t        \"success_effect\": \"exp:+30,reputation:+5,rel:npc_xiao_zhan:+5,item:+item_elixir\",\n578\t        \"failure_text\": \"准备不足令你在众目睽睽之下落败，族内质疑声愈发刺耳。\",\n579\t        \"failure_effect\": \"reputation:-5,rel:npc_xiao_zhan:-10,hp:-20\",\n580\t    },\n581\t    {\n582\t        \"id\": \"black_ring_deadline\",\n583\t        \"day\": 7,\n584\t        \"period\": 2,\n585\t        \"title\": \"后山之约\",\n586\t        \"description\": \"夕阳落下前，你必须带着足够的历练前往后山，查明黑色戒指的异动。\",\n587\t        \"goals\": {\"story_stage\": 2, \"adventure_points\": 3},\n588\t        \"success_text\": \"你如约抵达后山，戒指中传来一道苍老声音，新的道路由此展开。\",\n589\t        \"success_effect\": \"flag:ring_awakened=1,soul:+5,douqi:+5\",\n590\t        \"failure_text\": \"你错过了戒指最强烈的一次波动，只能付出更多时间重新寻找线索。\",\n591\t        \"failure_effect\": \"soul:-2,reputation:-2\",\n592\t    },\n593\t]\n594\t\n595\t\n596\tdef load_json(path: Path) -> Any:\n597\t    with path.open(\"r\", encoding=\"utf-8\") as file:\n598\t        return json.load(file)\n599\t\n600\t\n601\tclass GameEngine:\n602\t    def __init__(self, workbook_path: Path = WORKBOOK_PATH) -> None:\n603\t        data = load_game_data(workbook_path)\n604\t        self.events_list: List[Dict[str, Any]] = data[\"events\"]\n605\t        self.events: Dict[str, Dict[str, Any]] = {\n606\t            event[\"id\"]: event for event in self.events_list\n607\t        }\n608\t        self.start_event: str = data[\"start_event\"]\n609\t        self.attribute_rules: Dict[str, Dict[str, Any]] = data[\"attributes\"]\n610\t        self.flag_defaults: Dict[str, int] = data[\"flag_defaults\"]\n611\t        self.npc_names: Dict[str, str] = data[\"npc_names\"]\n612\t        relationship_list: List[Dict[str, Any]] = data[\"relationships\"]\n613\t        self.relationship_rules: Dict[str, Dict[str, Any]] = {\n614\t            rule[\"id\"]: rule for rule in relationship_list\n615\t        }\n616\t        self.relationship_index = self._build_relationship_index(relationship_list)\n617\t        self.level_progression: List[Dict[str, Any]] = data[\"level_progression\"]\n618\t        self.maps: Dict[str, Dict[str, Any]] = data[\"maps\"]\n619\t        self.encounters: List[Dict[str, Any]] = data[\"encounters\"]\n620\t        self.enemies: Dict[str, Dict[str, Any]] = data[\"enemies\"]\n621\t        self.item_rules: Dict[str, Dict[str, Any]] = data[\"items\"]\n622\t        self.skills: Dict[str, Dict[str, Any]] = data[\"skills\"]\n623\t        self.realms: List[Dict[str, Any]] = data[\"realms\"]\n624\t        self.active_encounter: Optional[Dict[str, Any]] = None\n625\t        self.combat: Optional[Dict[str, Any]] = None\n626\t        self.player: Dict[str, Any] = self._create_new_player()\n627\t        self.last_message: str = \"\"\n628\t\n629\t    def new_game(self, name: Optional[str] = None) -> None:\n630\t        self.player = self._create_new_player()\n631\t        if name:\n632\t            self.player[\"name\"] = name\n633\t        self.last_message = \"斗气大陆的故事由此开始。\"\n634\t\n635\t    def save(self) -> None:\n636\t        self._sync_story_phase_id()\n637\t        SAVE_PATH.parent.mkdir(parents=True, exist_ok=True)\n638\t        with SAVE_PATH.open(\"w\", encoding=\"utf-8\") as file:\n639\t            json.dump(self.player, file, ensure_ascii=False, indent=2)\n640\t\n641\t    def load(self) -> bool:\n642\t        if not SAVE_PATH.exists():\n643\t            return False\n644\t        self.player = load_json(SAVE_PATH)\n645\t        self._ensure_player_state()\n646\t        self.last_message = \"存档已读取，并已迁移到最新剧情数据。\"\n647\t        return True\n648\t\n649\t    def _create_new_player(self) -> Dict[str, Any]:\n650\t        player: Dict[str, Any] = {\n651\t            rule_id: rule[\"initial\"] for rule_id, rule in self.attribute_rules.items()\n652\t        }\n653\t        player.update(\n654\t            {\n655\t                \"name\": self.npc_names.get(\"player\", \"萧炎\"),\n656\t                \"max_hp\": self.attribute_rules[\"hp\"][\"initial\"],\n657\t                \"flags\": [\n658\t                    flag_id\n659\t                    for flag_id, default in self.flag_defaults.items()\n660\t                    if default\n661\t                ],\n662\t                \"items\": [],\n663\t                \"visited\": {},\n664\t                \"relationships\": {},\n665\t                \"relationship_triggers\": [],\n666\t                \"active_statuses\": [],\n667\t                \"current_event\": self.start_event,\n668\t                \"last_map\": \"map_wutan\",\n669\t                \"adventure_points\": 0,\n670\t                \"story_stage\": 0,\n671\t                \"story_phase_id\": STORY_PHASES[0][\"id\"],\n672\t                \"story_substage\": 0,\n673\t                \"known_skills\": [\"skill_bajibang\", \"skill_flame_mantra\"],\n674\t                \"day\": 1,\n675\t                \"time_period\": 0,\n676\t                \"completed_schedule_nodes\": [],\n677\t                \"pending_schedule_node\": \"\",\n678\t                \"training_wins\": 0,\n679\t            }\n680\t        )\n681\t        self._ensure_player_state(player)\n682\t        return player\n683\t\n684\t    def _ensure_player_state(self, player: Optional[Dict[str, Any]] = None) -> None:\n685\t        player = player if player is not None else self.player\n686\t\n687\t        nested_player = player.get(\"player\")\n688\t        if isinstance(nested_player, dict):\n689\t            player.setdefault(\"name\", nested_player.get(\"name\", \"萧炎\"))\n690\t            attributes = nested_player.get(\"attributes\", {})\n691\t            if isinstance(attributes, dict):\n692\t                for key, value in attributes.items():\n693\t                    player.setdefault(key, value)\n694\t\n695\t        for legacy_key, current_key in LEGACY_STAT_ALIASES.items():\n696\t            if current_key not in player and legacy_key in player:\n697\t                player[current_key] = player[legacy_key]\n698\t        for attribute_id, rule in self.attribute_rules.items():\n699\t            player.setdefault(attribute_id, rule[\"initial\"])\n700\t\n701\t        flags = player.get(\"flags\", [])\n702\t        if isinstance(flags, dict):\n703\t            player[\"flags\"] = [key for key, value in flags.items() if int(value)]\n704\t        else:\n705\t            player.setdefault(\"flags\", [])\n706\t        for flag_id, default in self.flag_defaults.items():\n707\t            if default and flag_id not in player[\"flags\"]:\n708\t                player[\"flags\"].append(flag_id)\n709\t\n710\t        if \"items\" not in player:\n711\t            inventory = player.get(\"inventory\", {})\n712\t            if isinstance(inventory, dict):\n713\t                player[\"items\"] = [\n714\t                    item_id for item_id, count in inventory.items() if int(count) > 0\n715\t                ]\n716\t            else:\n717\t                player[\"items\"] = []\n718\t\n719\t        player.setdefault(\"name\", self.npc_names.get(\"player\", \"萧炎\"))\n720\t        player.setdefault(\n721\t            \"max_hp\", max(self.attribute_rules[\"hp\"][\"initial\"], player[\"hp\"])\n722\t        )\n723\t        player.setdefault(\"visited\", {})\n724\t        player.setdefault(\"relationships\", {})\n725\t        player.setdefault(\"relationship_triggers\", [])\n726\t        player.setdefault(\"active_statuses\", [])\n727\t        player.setdefault(\"last_map\", \"map_wutan\")\n728\t        player.setdefault(\"adventure_points\", 0)\n729\t        if \"story_phase_id\" in player:\n730\t            phase_id = player[\"story_phase_id\"]\n731\t            matching_stage = next(\n732\t                (\n733\t                    index\n734\t                    for index, phase in enumerate(STORY_PHASES)\n735\t                    if phase[\"id\"] == phase_id\n736\t                ),\n737\t                len(STORY_PHASES) if not phase_id else None,\n738\t            )\n739\t            if matching_stage is not None:\n740\t                player[\"story_stage\"] = matching_stage\n741\t        else:\n742\t            old_stage = int(player.get(\"story_stage\", player.get(\"story_steps\", 0)))\n743\t            if 0 <= old_stage < len(LEGACY_STORY_PHASE_IDS_V2):\n744\t                old_phase_id = LEGACY_STORY_PHASE_IDS_V2[old_stage]\n745\t                player[\"story_stage\"] = next(\n746\t                    (\n747\t                        index\n748\t                        for index, phase in enumerate(STORY_PHASES)\n749\t                        if phase[\"id\"] == old_phase_id\n750\t                    ),\n751\t                    min(len(STORY_PHASES), old_stage),\n752\t                )\n753\t            else:\n754\t                player[\"story_stage\"] = min(len(STORY_PHASES), old_stage)\n755\t            player[\"story_phase_id\"] = (\n756\t                STORY_PHASES[player[\"story_stage\"]][\"id\"]\n757\t                if player[\"story_stage\"] < len(STORY_PHASES)\n758\t                else \"\"\n759\t            )\n760\t        player.setdefault(\"story_substage\", 0)\n761\t        player.setdefault(\"known_skills\", [\"skill_bajibang\", \"skill_flame_mantra\"])\n762\t        player.setdefault(\"day\", 1)\n763\t        player.setdefault(\"time_period\", 0)\n764\t        player.setdefault(\"completed_schedule_nodes\", [])\n765\t        player.setdefault(\"pending_schedule_node\", \"\")\n766\t        player.setdefault(\"training_wins\", 0)\n767\t        self._check_schedule_nodes(player)\n768\t        if player.get(\"current_event\") not in self.events:\n769\t            player[\"current_event\"] = self.start_event\n770\t        self._ensure_relationship_state(player)\n771\t        self._clamp_player_stats(player)\n772\t        self._apply_level_progression(player)\n773\t\n774\t    def _ensure_relationship_state(self, player: Optional[Dict[str, Any]] = None) -> None:\n775\t        player = player if player is not None else self.player\n776\t        values = player.setdefault(\"relationships\", {})\n777\t        for relation_id, rule in self.relationship_rules.items():\n778\t            values.setdefault(relation_id, int(rule.get(\"initial_value\", 0)))\n779\t\n780\t    @staticmethod\n781\t    def _build_relationship_index(\n782\t        relationship_list: List[Dict[str, Any]]\n783\t    ) -> Dict[str, str]:\n784\t        index: Dict[str, str] = {}\n785\t        for rule in relationship_list:\n786\t            relation_id = rule[\"id\"]\n787\t            source = rule[\"source\"]\n788\t            target = rule[\"target\"]\n789\t            index[relation_id] = relation_id\n790\t            index[f\"{source}>{target}\"] = relation_id\n791\t            if source == \"player\":\n792\t                index[target] = relation_id\n793\t            if rule.get(\"bidirectional\"):\n794\t                index[f\"{target}>{source}\"] = relation_id\n795\t        return index\n796\t\n797\t    def relation_rule(self, reference: str) -> Dict[str, Any]:\n798\t        relation_id = self.relationship_index.get(reference)\n799\t        if relation_id is None:\n800\t            raise KeyError(f\"未定义的关系：{reference}\")\n801\t        return self.relationship_rules[relation_id]\n802\t\n803\t    def relation_value(self, reference: str) -> int:\n804\t        rule = self.relation_rule(reference)\n805\t        return int(self.player[\"relationships\"][rule[\"id\"]])\n806\t\n807\t    def relation_stage(self, reference: str) -> str:\n808\t        rule = self.relation_rule(reference)\n809\t        value = self.relation_value(reference)\n810\t        stage = \"未定义\"\n811\t        thresholds = []\n812\t        for item in rule.get(\"stage_rule\", \"\").split(\"|\"):\n813\t            if not item:\n814\t                continue\n815\t            threshold, name = item.split(\":\", 1)\n816\t            thresholds.append((int(threshold), name))\n817\t        for threshold, name in sorted(thresholds):\n818\t            if value >= threshold:\n819\t                stage = name\n820\t        return stage\n821\t\n822\t    def set_relation_value(\n823\t        self, reference: str, value: int, evaluate_triggers: bool = True\n824\t    ) -> List[str]:\n825\t        rule = self.relation_rule(reference)\n826\t        relation_id = rule[\"id\"]\n827\t        old_value = self.relation_value(reference)\n828\t        new_value = max(\n829\t            int(rule.get(\"min_value\", -100)),\n830\t            min(int(rule.get(\"max_value\", 100)), int(value)),\n831\t        )\n832\t        self.player[\"relationships\"][relation_id] = new_value\n833\t        target_name = self.npc_names.get(rule[\"target\"], rule[\"target\"])\n834\t        logs = [f\"关系 {target_name} {old_value}->{new_value}\"]\n835\t        if evaluate_triggers:\n836\t            logs.extend(self._apply_on_reach_effect(rule))\n837\t        return logs\n838\t\n839\t    def change_relation_value(\n840\t        self, reference: str, delta: int, evaluate_triggers: bool = True\n841\t    ) -> List[str]:\n842\t        return self.set_relation_value(\n843\t            reference,\n844\t            self.relation_value(reference) + delta,\n845\t            evaluate_triggers=evaluate_triggers,\n846\t        )\n847\t\n848\t    def _apply_on_reach_effect(self, rule: Dict[str, Any]) -> List[str]:\n849\t        expression = rule.get(\"on_reach_effect\")\n850\t        if not expression:\n851\t            return []\n852\t        match = ON_REACH_PATTERN.match(expression)\n853\t        if not match or not self._check_condition_token(match.group(1)):\n854\t            return []\n855\t        trigger_id = f\"{rule['id']}:{expression}\"\n856\t        triggered: List[str] = self.player[\"relationship_triggers\"]\n857\t        if trigger_id in triggered:\n858\t            return []\n859\t        triggered.append(trigger_id)\n860\t        return self.apply_effects(match.group(2), evaluate_relationship_triggers=False)\n861\t\n862\t    def current_event(self) -> Dict[str, Any]:\n863\t        event_id = self.player.get(\"current_event\", self.start_event)\n864\t        if event_id not in self.events:\n865\t            event_id = self.start_event\n866\t            self.player[\"current_event\"] = event_id\n867\t        return self.events[event_id]\n868\t\n869\t    def mark_visited(self, event_id: str) -> None:\n870\t        visited = self.player.setdefault(\"visited\", {})\n871\t        visited[event_id] = visited.get(event_id, 0) + 1\n872\t\n873\t    @staticmethod\n874\t    def _compare(left: int, operator: str, right: int) -> bool:\n875\t        return {\n876\t            \">\": left > right,\n877\t            \">=\": left >= right,\n878\t            \"<\": left < right,\n879\t            \"<=\": left <= right,\n880\t            \"==\": left == right,\n881\t            \"!=\": left != right,\n882\t        }[operator]\n883\t\n884\t    @staticmethod\n885\t    def _canonical_stat(key: str) -> str:\n886\t        return LEGACY_STAT_ALIASES.get(key, key)\n887\t\n888\t    def _check_condition_token(self, token: str) -> bool:\n889\t        token = token.strip()\n890\t        if not token:\n891\t            return True\n892\t        if token.startswith(\"item:\"):\n893\t            return token[5:] in self.player.get(\"items\", [])\n894\t        if token.startswith(\"flag:\"):\n895\t            name, expected = token[5:].split(\"=\", 1)\n896\t            actual = 1 if name in self.player.get(\"flags\", []) else 0\n897\t            return actual == int(expected)\n898\t\n899\t        match = COMPARISON_PATTERN.match(token)\n900\t        if not match:\n901\t            raise ValueError(f\"不支持的条件表达式：{token}\")\n902\t        key, operator, raw_value = match.groups()\n903\t        if key.startswith(\"rel:\"):\n904\t            actual = self.relation_value(key[4:])\n905\t        else:\n906\t            actual = int(self.player.get(self._canonical_stat(key), 0))\n907\t        return self._compare(actual, operator, int(raw_value))\n908\t\n909\t    def check_conditions(self, conditions: Optional[Any]) -> bool:\n910\t        if not conditions:\n911\t            return True\n912\t        if isinstance(conditions, str):\n913\t            return all(\n914\t                self._check_condition_token(token) for token in conditions.split(\",\")\n915\t            )\n916\t\n917\t        player = self.player\n918\t        for stat, value in conditions.get(\"stat_min\", {}).items():\n919\t            if player.get(self._canonical_stat(stat), 0) < value:\n920\t                return False\n921\t        for stat, value in conditions.get(\"stat_max\", {}).items():\n922\t            if player.get(self._canonical_stat(stat), 0) > value:\n923\t                return False\n924\t        for flag in conditions.get(\"has_flags\", []):\n925\t            if flag not in player.get(\"flags\", []):\n926\t                return False\n927\t        for flag in conditions.get(\"not_flags\", []):\n928\t            if flag in player.get(\"flags\", []):\n929\t                return False\n930\t        for item in conditions.get(\"has_items\", []):\n931\t            if item not in player.get(\"items\", []):\n932\t                return False\n933\t        for item in conditions.get(\"not_items\", []):\n934\t            if item in player.get(\"items\", []):\n935\t                return False\n936\t        return True\n937\t\n938\t    def available_options(\n939\t        self, event: Optional[Dict[str, Any]] = None\n940\t    ) -> List[Tuple[int, Dict[str, Any]]]:\n941\t        event = event or self.current_event()\n942\t        if not self.check_conditions(event.get(\"conditions\")):\n943\t            return []\n944\t        result = []\n945\t        for index, option in enumerate(event.get(\"options\", []), start=1):\n946\t            if self.check_conditions(option.get(\"conditions\")):\n947\t                result.append((index, option))\n948\t        return result\n949\t\n950\t    def _apply_effect_token(\n951\t        self, token: str, evaluate_relationship_triggers: bool\n952\t    ) -> List[str]:\n953\t        token = token.strip()\n954\t        if not token:\n955\t            return []\n956\t\n957\t        match = RELATION_EFFECT_PATTERN.match(token)\n958\t        if match:\n959\t            return self.change_relation_value(\n960\t                match.group(1),\n961\t                int(match.group(2)),\n962\t                evaluate_triggers=evaluate_relationship_triggers,\n963\t            )\n964\t        match = RELATION_SET_PATTERN.match(token)\n965\t        if match:\n966\t            return self.set_relation_value(\n967\t                match.group(1),\n968\t                int(match.group(2)),\n969\t                evaluate_triggers=evaluate_relationship_triggers,\n970\t            )\n971\t        if token.startswith(\"item:+\"):\n972\t            item = token[6:]\n973\t            if item not in self.player[\"items\"]:\n974\t                self.player[\"items\"].append(item)\n975\t            return [f\"获得道具：{self.item_name(item)}\"]\n976\t        if token.startswith(\"item:-\"):\n977\t            item = token[6:]\n978\t            if item in self.player[\"items\"]:\n979\t                self.player[\"items\"].remove(item)\n980\t            return [f\"失去道具：{self.item_name(item)}\"]\n981\t        if token.startswith(\"flag:\"):\n982\t            name, raw_value = token[5:].split(\"=\", 1)\n983\t            flags = self.player[\"flags\"]\n984\t            if int(raw_value) and name not in flags:\n985\t                flags.append(name)\n986\t            elif not int(raw_value) and name in flags:\n987\t                flags.remove(name)\n988\t            return [f\"剧情开关 {name}={raw_value}\"]\n989\t        if token.startswith(\"status:+\"):\n990\t            status = token[8:]\n991\t            if status not in self.player[\"active_statuses\"]:\n992\t                self.player[\"active_statuses\"].append(status)\n993\t            return [f\"获得状态：{status}\"]\n994\t        if token.startswith(\"status:-\"):\n995\t            status = token[8:]\n996\t            if status in self.player[\"active_statuses\"]:\n997\t                self.player[\"active_statuses\"].remove(status)\n998\t            return [f\"移除状态：{status}\"]\n999\t\n1000\t        key, raw_value = token.split(\":\", 1)\n1001\t        key = self._canonical_stat(key)\n1002\t        if key not in self.attribute_rules:\n1003\t            raise ValueError(f\"不支持的效果表达式：{token}\")\n1004\t        value = int(raw_value)\n1005\t        self.player[key] = self.player.get(key, 0) + value\n1006\t        sign = \"+\" if value >= 0 else \"\"\n1007\t        return [f\"{self.attribute_rules[key]['name']} {sign}{value}\"]\n1008\t\n1009\t    def apply_effects(\n1010\t        self,\n1011\t        effects: Optional[Any],\n1012\t        evaluate_relationship_triggers: bool = True,\n1013\t    ) -> List[str]:\n1014\t        if not effects:\n1015\t            return []\n1016\t        if isinstance(effects, str):\n1017\t            logs: List[str] = []\n1018\t            for token in effects.split(\",\"):\n1019\t                logs.extend(\n1020\t                    self._apply_effect_token(token, evaluate_relationship_triggers)\n1021\t                )\n1022\t            self._clamp_player_stats()\n1023\t            logs.extend(self._apply_level_progression())\n1024\t            return logs\n1025\t\n1026\t        logs: List[str] = []\n1027\t        for key, value in effects.items():\n1028\t            canonical_key = self._canonical_stat(key)\n1029\t            if canonical_key in self.attribute_rules:\n1030\t                self.player[canonical_key] = self.player.get(canonical_key, 0) + value\n1031\t                logs.append(f\"{self.attribute_rules[canonical_key]['name']} {value:+d}\")\n1032\t        self._clamp_player_stats()\n1033\t        logs.extend(self._apply_level_progression())\n1034\t        return logs\n1035\t\n1036\t    def _clamp_player_stats(self, player: Optional[Dict[str, Any]] = None) -> None:\n1037\t        player = player if player is not None else self.player\n1038\t        for attribute_id, rule in self.attribute_rules.items():\n1039\t            value = int(player.get(attribute_id, rule[\"initial\"]))\n1040\t            player[attribute_id] = max(rule[\"min\"], min(rule[\"max\"], value))\n1041\t\n1042\t    def _progression_rule(self, level: int) -> Optional[Dict[str, Any]]:\n1043\t        for rule in self.level_progression:\n1044\t            if rule[\"min_level\"] <= level <= rule[\"max_level\"]:\n1045\t                return rule\n1046\t        return None\n1047\t\n1048\t    @staticmethod\n1049\t    def _required_exp(level: int, formula: str) -> Optional[int]:\n1050\t        match = EXP_FORMULA_PATTERN.match(formula)\n1051\t        return level * int(match.group(1)) if match else None\n1052\t\n1053\t    def _apply_level_progression(\n1054\t        self, player: Optional[Dict[str, Any]] = None\n1055\t    ) -> List[str]:\n1056\t        player = player if player is not None else self.player\n1057\t        logs: List[str] = []\n1058\t        while True:\n1059\t            level = int(player.get(\"level\", 1))\n1060\t            rule = self._progression_rule(level)\n1061\t            if rule is None:\n1062\t                break\n1063\t            required_exp = self._required_exp(level, rule[\"exp_formula\"])\n1064\t            if required_exp is None or int(player.get(\"exp\", 0)) < required_exp:\n1065\t                break\n1066\t\n1067\t            player[\"level\"] = level + 1\n1068\t            for attribute_id, gain in rule[\"gains\"].items():\n1069\t                player[attribute_id] = player.get(attribute_id, 0) + gain\n1070\t                if attribute_id == \"hp\":\n1071\t                    player[\"max_hp\"] = player.get(\"max_hp\", player[\"hp\"]) + gain\n1072\t            self._clamp_player_stats(player)\n1073\t            logs.append(f\"境界等级提升至 {level + 1}\")\n1074\t            skill_id = LEVEL_SKILL_MILESTONES.get(level + 1)\n1075\t            if skill_id and skill_id not in player[\"known_skills\"]:\n1076\t                player[\"known_skills\"].append(skill_id)\n1077\t                logs.append(f\"领悟斗技：{self.skills[skill_id]['name']}\")\n1078\t        return logs\n1079\t\n1080\t    def eligible_random_events(self) -> List[Dict[str, Any]]:\n1081\t        return [\n1082\t            event\n1083\t            for event in self.events_list\n1084\t            if event.get(\"pool\") not in {\"\", \"main\"}\n1085\t            and self.check_conditions(event.get(\"conditions\"))\n1086\t        ]\n1087\t\n1088\t    def choose_random_event_id(self) -> str:\n1089\t        candidates = self.eligible_random_events()\n1090\t        if not candidates:\n1091\t            return self.player.get(\"current_event\", self.start_event)\n1092\t        weights = [max(1, int(event.get(\"weight\", 1))) for event in candidates]\n1093\t        return random.choices(candidates, weights=weights, k=1)[0][\"id\"]\n1094\t\n1095\t    def resolve_next(self, option: Dict[str, Any]) -> str:\n1096\t        next_id = option.get(\"next\", \"\")\n1097\t        if not next_id:\n1098\t            return self.player.get(\"current_event\", self.start_event)\n1099\t        if next_id == \"random\":\n1100\t            return self.choose_random_event_id()\n1101\t        if \"|\" in next_id:\n1102\t            branches = []\n1103\t            for branch in next_id.split(\"|\"):\n1104\t                event_id, weight = branch.rsplit(\":\", 1)\n1105\t                branches.append((event_id, max(1, int(weight))))\n1106\t            return random.choices(\n1107\t                [branch[0] for branch in branches],\n1108\t                weights=[branch[1] for branch in branches],\n1109\t                k=1,\n1110\t            )[0]\n1111\t        return next_id\n1112\t\n1113\t    def choose_option(self, visible_option_number: int) -> bool:\n1114\t        event = self.current_event()\n1115\t        option_map = {index: option for index, option in self.available_options(event)}\n1116\t        if visible_option_number not in option_map:\n1117\t            self.last_message = \"无效选择，或当前条件尚未满足。\"\n1118\t            return False\n1119\t\n1120\t        self.mark_visited(event[\"id\"])\n1121\t        option = option_map[visible_option_number]\n1122\t        logs = self.apply_effects(option.get(\"effects\"))\n1123\t        next_id = self.resolve_next(option)\n1124\t        if next_id in self.events:\n1125\t            self.player[\"current_event\"] = next_id\n1126\t        else:\n1127\t            logs.append(f\"暂不支持的跳转：{next_id}\")\n1128\t        self.last_message = \"；\".join(logs) if logs else \"继续前行。\"\n1129\t        return True\n1130\t\n1131\t    def realm_name(self) -> str:\n1132\t        level = int(self.player.get(\"level\", 1))\n1133\t        for realm in self.realms:\n1134\t            if realm[\"min_level\"] <= level <= realm[\"max_level\"]:\n1135\t                return realm[\"name\"]\n1136\t        return \"未知境界\"\n1137\t\n1138\t    def current_map(self) -> Dict[str, Any]:\n1139\t        return self.maps.get(self.player.get(\"last_map\", \"\"), self.maps[\"map_wutan\"])\n1140\t\n1141\t    def time_text(self) -> str:\n1142\t        return f\"第{self.player['day']}日 {TIME_PERIODS[self.player['time_period']]}\"\n1143\t\n1144\t    def is_night(self) -> bool:\n1145\t        return int(self.player[\"time_period\"]) >= 2\n1146\t\n1147\t    def pending_schedule_node(self) -> Optional[Dict[str, Any]]:\n1148\t        node_id = self.player.get(\"pending_schedule_node\", \"\")\n1149\t        return next((node for node in SCHEDULE_NODES if node[\"id\"] == node_id), None)\n1150\t\n1151\t    def next_schedule_node(self) -> Optional[Dict[str, Any]]:\n1152\t        completed = set(self.player.get(\"completed_schedule_nodes\", []))\n1153\t        return next((node for node in SCHEDULE_NODES if node[\"id\"] not in completed), None)\n1154\t\n1155\t    def schedule_text(self, node: Dict[str, Any]) -> str:\n1156\t        goals = []\n1157\t        for key, required in node[\"goals\"].items():\n1158\t            names = {\n1159\t                \"level\": \"等级\",\n1160\t                \"training_wins\": \"切磋胜场\",\n1161\t                \"story_steps\": \"主线进度\",\n1162\t                \"story_stage\": \"关键阶段\",\n1163\t                \"adventure_points\": \"冒险阅历\",\n1164\t            }\n1165\t            goals.append(f\"{names.get(key, key)} {self.player.get(key, 0)}/{required}\")\n1166\t        return (\n1167\t            f\"{node['title']}｜第{node['day']}日 {TIME_PERIODS[node['period']]}\\n\"\n1168\t            f\"{node['description']}\\n目标：\" + \"、\".join(goals)\n1169\t        )\n1170\t\n1171\t    def schedule_countdown_text(self, node: Dict[str, Any]) -> str:\n1172\t        node_time = (node[\"day\"] - 1) * len(TIME_PERIODS) + node[\"period\"]\n1173\t        remaining = max(0, node_time - self._absolute_time())\n1174\t        days, periods = divmod(remaining, len(TIME_PERIODS))\n1175\t        parts = []\n1176\t        if days:\n1177\t            parts.append(f\"{days}日\")\n1178\t        if periods:\n1179\t            parts.append(f\"{periods}个时段\")\n1180\t        return \"剩余\" + (\"\".join(parts) if parts else \"时间已到\")\n1181\t\n1182\t    def _can_take_free_action(self) -> bool:\n1183\t        if self.pending_schedule_node() is None:\n1184\t            return True\n1185\t        self.last_message = \"当前有必须处理的日程节点，无法进行其他行动。\"\n1186\t        return False\n1187\t\n1188\t    def _absolute_time(self, player: Optional[Dict[str, Any]] = None) -> int:\n1189\t        player = player if player is not None else self.player\n1190\t        return (int(player[\"day\"]) - 1) * len(TIME_PERIODS) + int(player[\"time_period\"])\n1191\t\n1192\t    def _check_schedule_nodes(self, player: Optional[Dict[str, Any]] = None) -> None:\n1193\t        player = player if player is not None else self.player\n1194\t        if player.get(\"pending_schedule_node\"):\n1195\t            return\n1196\t        completed = set(player.get(\"completed_schedule_nodes\", []))\n1197\t        current_time = self._absolute_time(player)\n1198\t        for node in SCHEDULE_NODES:\n1199\t            node_time = (node[\"day\"] - 1) * len(TIME_PERIODS) + node[\"period\"]\n1200\t            if node[\"id\"] not in completed and current_time >= node_time:\n1201\t                player[\"pending_schedule_node\"] = node[\"id\"]\n1202\t                return\n1203\t\n1204\t    def advance_time(self, periods: int = 1) -> None:\n1205\t        absolute = self._absolute_time() + max(0, periods)\n1206\t        self.player[\"day\"] = absolute // len(TIME_PERIODS) + 1\n1207\t        self.player[\"time_period\"] = absolute % len(TIME_PERIODS)\n1208\t        self._check_schedule_nodes()\n1209\t\n1210\t    def resolve_schedule_node(self) -> bool:\n1211\t        node = self.pending_schedule_node()\n1212\t        if node is None:\n1213\t            self.last_message = \"当前没有必须处理的日程。\"\n1214\t            return False\n1215\t        success = all(\n1216\t            int(self.player.get(key, 0)) >= required\n1217\t            for key, required in node[\"goals\"].items()\n1218\t        )\n1219\t        result_text = node[\"success_text\"] if success else node[\"failure_text\"]\n1220\t        effects = node[\"success_effect\"] if success else node[\"failure_effect\"]\n1221\t        logs = self.apply_effects(effects)\n1222\t        self.player[\"completed_schedule_nodes\"].append(node[\"id\"])\n1223\t        self.player[\"pending_schedule_node\"] = \"\"\n1224\t        self.last_message = (\n1225\t            f\"{'达标' if success else '未达标'}：{result_text}\"\n1226\t            + (\"；\" + \"；\".join(logs) if logs else \"\")\n1227\t        )\n1228\t        self._check_schedule_nodes()\n1229\t        return success\n1230\t\n1231\t    def available_maps(self) -> List[Dict[str, Any]]:\n1232\t        return [map_rule for map_rule in self.maps.values() if self.is_map_unlocked(map_rule[\"id\"])]\n1233\t\n1234\t    def is_map_unlocked(self, map_id: str) -> bool:\n1235\t        phase_id = MAP_STORY_UNLOCKS.get(map_id)\n1236\t        if phase_id is None:\n1237\t            return False\n1238\t        required_stage = next(\n1239\t            (\n1240\t                index\n1241\t                for index, phase in enumerate(STORY_PHASES)\n1242\t                if phase[\"id\"] == phase_id\n1243\t            ),\n1244\t            len(STORY_PHASES),\n1245\t        )\n1246\t        return int(self.player.get(\"story_stage\", 0)) >= required_stage\n1247\t\n1248\t    def map_unlock_text(self, map_id: str) -> str:\n1249\t        phase_id = MAP_STORY_UNLOCKS.get(map_id)\n1250\t        phase = next((phase for phase in STORY_PHASES if phase[\"id\"] == phase_id), None)\n1251\t        return f\"推进至“{phase['title']}”开放\" if phase else \"尚无开放剧情\"\n1252\t\n1253\t    def travel(self, map_id: str) -> bool:\n1254\t        if not self._can_take_free_action():\n1255\t            return False\n1256\t        map_rule = self.maps.get(map_id)\n1257\t        if map_rule is None or not self.is_map_unlocked(map_id):\n1258\t            self.last_message = (\n1259\t                f\"该区域尚未开放。{self.map_unlock_text(map_id)}\"\n1260\t                if map_rule is not None\n1261\t                else \"不存在该区域。\"\n1262\t            )\n1263\t            return False\n1264\t        if self.player[\"time_period\"] == 3 and not map_rule[\"safe_zone\"]:\n1265\t            self.last_message = \"深夜无法安全前往危险区域，请等到天亮。\"\n1266\t            return False\n1267\t        self.player[\"last_map\"] = map_id\n1268\t        self.active_encounter = None\n1269\t        self.advance_time()\n1270\t        self.last_message = f\"你抵达了{map_rule['name']}。{map_rule['description']}\"\n1271\t        return True\n1272\t\n1273\t    def rest(self) -> None:\n1274\t        if not self._can_take_free_action():\n1275\t            return\n1276\t        self.player[\"hp\"] = self.player[\"max_hp\"]\n1277\t        self.player[\"stamina\"] = self.attribute_rules[\"stamina\"][\"initial\"]\n1278\t        periods = len(TIME_PERIODS) - int(self.player[\"time_period\"])\n1279\t        self.advance_time(periods)\n1280\t        self.last_message = f\"你休整到{self.time_text()}，生命与体力已经恢复。\"\n1281\t\n1282\t    def cultivate(self) -> bool:\n1283\t        if not self._can_take_free_action():\n1284\t            return False\n1285\t        if self.player[\"stamina\"] < 10:\n1286\t            self.last_message = \"体力不足，先休息再修炼。\"\n1287\t            return False\n1288\t        self.player[\"stamina\"] -= 10\n1289\t        soul_gain = 2 if self.is_night() else 1\n1290\t        self.player[\"adventure_points\"] += 1\n1291\t        if \"ring_awakened\" not in self.player[\"flags\"]:\n1292\t            logs = self.apply_effects(f\"soul:+{soul_gain}\")\n1293\t            action_text = \"药老尚未苏醒，你只能感知戒指异动、锤炼灵魂。\"\n1294\t        else:\n1295\t            logs = self.apply_effects(f\"exp:+10,douqi:+2,soul:+{soul_gain}\")\n1296\t            action_text = \"你依照药老指导运转斗气，完成了一轮修炼。\"\n1297\t        self.advance_time()\n1298\t        self.last_message = action_text + \"；获得冒险阅历 +1\"\n1299\t        if logs:\n1300\t            self.last_message += \"；\" + \"；\".join(logs)\n1301\t        return True\n1302\t\n1303\t    def explore(self) -> Optional[Dict[str, Any]]:\n1304\t        if not self._can_take_free_action():\n1305\t            return None\n1306\t        map_rule = self.current_map()\n1307\t        night_cost = 2 if self.is_night() else 0\n1308\t        cost = map_rule[\"stamina_cost\"] + night_cost\n1309\t        if self.player[\"stamina\"] < cost:\n1310\t            self.last_message = \"体力不足，无法继续探索。\"\n1311\t            return None\n1312\t        self.player[\"stamina\"] -= cost\n1313\t        candidates = [\n1314\t            encounter\n1315\t            for encounter in self.encounters\n1316\t            if encounter[\"map_id\"] == map_rule[\"id\"]\n1317\t            and self.check_conditions(encounter.get(\"conditions\"))\n1318\t        ]\n1319\t        if not candidates:\n1320\t            self.player[\"adventure_points\"] += 1\n1321\t            self.advance_time()\n1322\t            self.last_message = f\"你探索了{map_rule['name']}，但没有特别发现。\"\n1323\t            return None\n1324\t        self.active_encounter = random.choices(\n1325\t            candidates,\n1326\t            weights=[max(1, encounter[\"weight\"]) for encounter in candidates],\n1327\t            k=1,\n1328\t        )[0]\n1329\t        self.last_message = self.active_encounter[\"text\"]\n1330\t        return self.active_encounter\n1331\t\n1332\t    def encounter_options(self) -> List[Tuple[int, Dict[str, Any]]]:\n1333\t        if self.active_encounter is None:\n1334\t            return []\n1335\t        return [\n1336\t            (index, option)\n1337\t            for index, option in enumerate(self.active_encounter[\"options\"], start=1)\n1338\t            if self.check_conditions(option.get(\"conditions\"))\n1339\t        ]\n1340\t\n1341\t    def choose_encounter_option(self, option_number: int) -> bool:\n1342\t        option_map = {index: option for index, option in self.encounter_options()}\n1343\t        if option_number not in option_map:\n1344\t            self.last_message = \"当前无法选择该行动。\"\n1345\t            return False\n1346\t        option = option_map[option_number]\n1347\t        logs = self.apply_effects(option.get(\"effects\"))\n1348\t        next_id = option.get(\"next\", \"\")\n1349\t        encounter_text = self.active_encounter[\"text\"] if self.active_encounter else \"\"\n1350\t        self.active_encounter = None\n1351\t        self.player[\"adventure_points\"] += 1\n1352\t        if self.is_night():\n1353\t            self.player[\"adventure_points\"] += 1\n1354\t            logs.append(\"夜间探索额外获得 1 点冒险阅历\")\n1355\t        if next_id.startswith(\"combat:\"):\n1356\t            self.combat_time_cost = 1\n1357\t            self.begin_combat(next_id[7:])\n1358\t            if logs:\n1359\t                self.last_message = \"；\".join(logs) + \"；\" + self.last_message\n1360\t        else:\n1361\t            self.advance_time()\n1362\t            self.last_message = \"；\".join(logs) if logs else f\"你处理了这次遭遇：{encounter_text}\"\n1363\t        return True\n1364\t\n1365\t    def begin_training_combat(self) -> bool:\n1366\t        if not self._can_take_free_action():\n1367\t            return False\n1368\t        level = int(self.player[\"level\"])\n1369\t        self.combat_time_cost = 1\n1370\t        self.combat_is_training = True\n1371\t        self.combat = {\n1372\t            \"enemy_id\": \"training_opponent\",\n1373\t            \"name\": \"萧家陪练弟子\",\n1374\t            \"level\": level,\n1375\t            \"hp\": 30 + level * 8,\n1376\t            \"max_hp\": 30 + level * 8,\n1377\t            \"atk\": 5 + level * 2,\n1378\t            \"def\": 2 + level,\n1379\t            \"spd\": 5 + level,\n1380\t            \"exp_reward\": 10 + level * 4,\n1381\t            \"drop_table\": \"\",\n1382\t            \"round\": 1,\n1383\t            \"defending\": False,\n1384\t            \"can_escape\": True,\n1385\t        }\n1386\t        self.last_message = \"陪练弟子摆开架势，回合战斗开始。\"\n1387\t        return True\n1388\t\n1389\t    def begin_combat(self, enemy_id: str) -> bool:\n1390\t        enemy = self.enemies.get(enemy_id)\n1391\t        if enemy is None:\n1392\t            self.last_message = f\"未找到敌人配置：{enemy_id}\"\n1393\t            return False\n1394\t        level = int(self.player[\"level\"])\n1395\t        enemy_level = max(level, min(enemy[\"level\"], level + 4))\n1396\t        hp = max(35, min(enemy[\"hp\"], 35 + enemy_level * 18))\n1397\t        self.combat = {\n1398\t            \"enemy_id\": enemy_id,\n1399\t            \"name\": enemy[\"name\"],\n1400\t            \"level\": enemy_level,\n1401\t            \"hp\": hp,\n1402\t            \"max_hp\": hp,\n1403\t            \"atk\": max(5, min(enemy[\"atk\"], 7 + enemy_level * 3)),\n1404\t            \"def\": max(1, min(enemy[\"def\"], 3 + enemy_level * 2)),\n1405\t            \"spd\": max(4, min(enemy[\"spd\"], 6 + enemy_level * 2)),\n1406\t            \"exp_reward\": max(10, min(enemy[\"exp_reward\"], 12 + enemy_level * 8)),\n1407\t            \"drop_table\": enemy[\"drop_table\"],\n1408\t            \"round\": 1,\n1409\t            \"defending\": False,\n1410\t            \"can_escape\": enemy[\"type\"] not in {\"boss\", \"final_boss\"},\n1411\t        }\n1412\t        self.combat_is_training = False\n1413\t        self.last_message = f\"{enemy['name']}挡住了去路，回合战斗开始。\"\n1414\t        return True\n1415\t\n1416\t    def combat_text(self) -> str:\n1417\t        if self.combat is None:\n1418\t            return \"\"\n1419\t        return (\n1420\t            f\"第{self.combat['round']}回合｜{self.combat['name']} \"\n1421\t            f\"生命 {self.combat['hp']}/{self.combat['max_hp']}\\n\"\n1422\t            f\"{self.player['name']} 生命 {self.player['hp']}｜斗气 {self.player['douqi']}\"\n1423\t        )\n1424\t\n1425\t    def combat_skills(self) -> List[Dict[str, Any]]:\n1426\t        return [\n1427\t            self.skills[skill_id]\n1428\t            for skill_id in self.player.get(\"known_skills\", [])\n1429\t            if skill_id in self.skills\n1430\t        ]\n1431\t\n1432\t    @staticmethod\n1433\t    def _skill_attack_bonus(effect: str) -> int:\n1434\t        for token in effect.split(\",\"):\n1435\t            if token.startswith(\"atk:+\"):\n1436\t                return int(token[5:])\n1437\t        return 0\n1438\t\n1439\t    def _skill_cost(self, skill: Dict[str, Any]) -> int:\n1440\t        return max(2, 2 + self._skill_attack_bonus(skill[\"effect\"]) // 15)\n1441\t\n1442\t    def _estimated_attack_damage(self, bonus: int = 0, multiplier: float = 1.0) -> int:\n1443\t        if self.combat is None:\n1444\t            return 0\n1445\t        return max(1, int((self.player[\"atk\"] + bonus) * multiplier) - self.combat[\"def\"])\n1446\t\n1447\t    @staticmethod\n1448\t    def _effect_gain(effect: str, stat: str) -> int:\n1449\t        prefix = f\"{stat}:+\"\n1450\t        for token in effect.split(\",\"):\n1451\t            if token.startswith(prefix):\n1452\t                return int(token[len(prefix):])"}]},"uuid":"ca45f5b8-6cee-4634-8446-4a3b157d431b","timestamp":"2026-06-09T00:52:21.526Z","toolUseResult":{"type":"text","file":{"filePath":"D:\\work\\wordworld\\src\\wordworld\\core\\engine.py","content":"import json\nimport random\nimport re\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional, Tuple\n\nfrom wordworld.data.workbook import load_game_data\nfrom wordworld.config.paths import SAVE_PATH, WORKBOOK_PATH\n\n\nLEGACY_STAT_ALIASES = {\n    \"attack\": \"atk\",\n    \"defense\": \"def\",\n    \"gold\": \"silver\",\n    \"neili\": \"douqi\",\n}\n\nCOMPARISON_PATTERN = re.compile(r\"^(.+?)(>=|<=|==|!=|>|<)(-?\\d+)$\")\nRELATION_EFFECT_PATTERN = re.compile(r\"^rel:([^:=]+):([+-]\\d+)$\")\nRELATION_SET_PATTERN = re.compile(r\"^rel:([^:=]+)=(-?\\d+)$\")\nON_REACH_PATTERN = re.compile(r\"^(rel:.+?(?:>=|<=|==|!=|>|<)-?\\d+):(.*)$\")\nEXP_FORMULA_PATTERN = re.compile(r\"^level\\*(\\d+)$\")\n\nLEVEL_SKILL_MILESTONES = {\n    10: \"skill_alchemy\",\n    20: \"skill_wind_thunder\",\n    30: \"skill_flame\",\n    40: \"skill_healing\",\n    50: \"skill_gold_flame\",\n}\n\nTIME_PERIODS = [\"清晨\", \"午后\", \"傍晚\", \"深夜\"]\n\n# 自动战斗中的终结类斗技只会在敌方生命不高于该比例时使用。\nFINISHER_SKILLS = {\n    \"skill_buddha_lotus\": 0.30,\n    \"skill_great_silence_finger\": 0.30,\n    \"skill_huangquan_finger\": 0.30,\n    \"skill_annihilate_sky_seal\": 0.30,\n}\n\n# 上一版存档只保存数字阶段。该列表用于把旧数字位置迁移到稳定阶段 ID。\nLEGACY_STORY_PHASE_IDS_V2 = [\n    \"fallen_genius\", \"three_year_pact\", \"ring_awakening\", \"wutan_growth\",\n    \"mountain_training\", \"desert_flame\", \"alchemy_conference\", \"yunlan_duel\",\n    \"canaan_outer\", \"canaan_inner\", \"fallen_heart\", \"black_corner_war\",\n    \"yunlan_war\", \"zhongzhou_arrival\", \"dan_meeting_flame\", \"save_mentor\",\n    \"ancient_ruins\", \"gu_clan_tomb\", \"bodhi_tree\", \"tianfu_alliance\",\n    \"demon_flame\", \"medicine_ceremony\", \"ancient_clan_war\", \"ancient_emperor\",\n    \"final_war\", \"five_emperors\",\n]\n\n\ndef _story_phase(\n    phase_id: str,\n    title: str,\n    background: str,\n    objective: str,\n    risk: str,\n    requirement: int,\n    condition: str,\n    effect: str,\n    subnodes: List[Tuple[str, str, str, str]],\n) -> Dict[str, Any]:\n    return {\n        \"id\": phase_id,\n        \"title\": title,\n        \"background\": background,\n        \"objective\": objective,\n        \"risk\": risk,\n        \"requirement\": requirement,\n        \"condition\": condition,\n        \"effect\": effect,\n        \"subnodes\": [\n            {\n                \"title\": node_title,\n                \"objective\": node_objective,\n                \"condition\": node_condition,\n                \"effect\": node_effect,\n            }\n            for node_title, node_objective, node_condition, node_effect in subnodes\n        ],\n    }\n\n\n# 主线必须按因果顺序显式排列，禁止再通过列表插入拼接时间线。\nSTORY_PHASES = [\n    _story_phase(\"fallen_genius\", \"天才陨落\", \"斗气持续衰退，族内试炼迫近。\", \"稳住根基并重新证明自己。\", \"失败会失去族内资源与信任。\", 2, \"level>=2\", \"reputation:+3,rel:npc_xiao_zhan:+3\", [\n        (\"查明斗气衰退\", \"观察身体与戒指的异常。\", \"soul>=5\", \"soul:+1\"),\n        (\"族内试炼翻身\", \"在演武场重新证明实力。\", \"training_wins>=1\", \"reputation:+3\"),\n    ]),\n    _story_phase(\"three_year_pact\", \"退婚与三年之约\", \"云岚宗登门退婚，萧家尊严受到挑战。\", \"维护家族尊严并立下三年之约。\", \"软弱回应会让萧家声望受损。\", 3, \"reputation>=5\", \"flag:three_year_pact=1,rel:npc_nalan_yanran:-10\", [\n        (\"应对退婚\", \"在大厅冲突中维护萧家尊严。\", \"reputation>=5\", \"rel:npc_xiao_zhan:+5\"),\n        (\"立下三年之约\", \"公开承担未来决战的责任。\", \"level>=3\", \"flag:three_year_pact=1,reputation:+5\"),\n    ]),\n    _story_phase(\"ring_awakening\", \"戒中导师\", \"退婚风波后，戒中的神秘灵魂终于现身。\", \"建立师徒关系并获得成长道路。\", \"无法取得信任会失去关键指导。\", 3, \"soul>=6,flag:three_year_pact=1\", \"flag:ring_awakened=1,rel:npc_yao_lao:+10,douqi:+5\", [\n        (\"药老现身\", \"确认斗气流失的真正原因。\", \"soul>=6\", \"flag:ring_awakened=1\"),\n        (\"学习炼药与焚决\", \"建立师徒信任并选择成长路线。\", \"adventure_points>=3\", \"rel:npc_yao_lao:+10,alchemy:+3\"),\n    ]),\n    _story_phase(\"wutan_growth\", \"乌坦城成长\", \"离开家族前，你需要功法、资金与实战经验。\", \"解决坊市冲突并完成离家准备。\", \"基础不足会使后续历练举步维艰。\", 4, \"level>=4\", \"flag:left_wutan=1,reputation:+5\", [\n        (\"经营坊市资源\", \"通过炼药、交易或探索筹集资源。\", \"silver>=20\", \"alchemy:+2\"),\n        (\"解决家族冲突\", \"保护萧家利益并赢得成人认可。\", \"training_wins>=2\", \"reputation:+5\"),\n        (\"告别家族\", \"准备独自踏上历练之路。\", \"adventure_points>=5\", \"flag:left_wutan=1\"),\n    ]),\n    _story_phase(\"mountain_training\", \"魔兽山脉历练\", \"魔兽山脉中有药材、强敌与新的伙伴。\", \"完成独立生存训练并穿越山脉。\", \"缺乏实战会无法深入沙漠。\", 5, \"level>=6,flag:left_wutan=1\", \"rel:npc_xiao_yixian:+10,exp:+50\", [\n        (\"青山镇立足\", \"建立补给点并了解山脉情报。\", \"adventure_points>=6\", \"reputation:+3\"),\n        (\"结识小医仙\", \"共同探索遗迹并建立信任。\", \"reputation>=10\", \"rel:npc_xiao_yixian:+10\"),\n        (\"面对厄难毒体\", \"帮助伙伴控制危险体质。\", \"rel:npc_xiao_yixian>=35\", \"flag:poison_companion=1\"),\n    ]),\n    _story_phase(\"desert_flame\", \"塔戈尔沙漠与青莲地心火\", \"异火线索指向蛇人族领地。\", \"深入沙漠并夺取青莲地心火。\", \"异火争夺失败会严重拖慢成长。\", 6, \"level>=10\", \"item:+item_green_lotus_flame,rel:npc_cai_lin:+15,douqi:+20\", [\n        (\"保护青鳞\", \"解决石漠城危机并保护青鳞。\", \"reputation>=10\", \"rel:npc_qing_lin:+10\"),\n        (\"寻找青莲地心火\", \"追踪地穴中的异火线索。\", \"soul>=12\", \"flag:green_lotus_found=1\"),\n        (\"美杜莎神殿争夺\", \"在多方冲突中取得异火并保留转圜余地。\", \"level>=10,rel:npc_cai_lin>=-40\", \"rel:npc_cai_lin:+10\"),\n    ]),\n    _story_phase(\"alchemy_conference\", \"炼药师大会\", \"返回加玛帝国后，炼药师大会成为积累声望的关键机会。\", \"通过考核、解决丹王势力威胁并夺得大会认可。\", \"失败会失去帝都盟友与公开声望。\", 7, \"alchemy>=12,soul>=12\", \"reputation:+10,alchemy:+5,item:+item_elixir\", [\n        (\"取得炼药师资格\", \"通过公会测试并获得参赛身份。\", \"alchemy>=10\", \"reputation:+3\"),\n        (\"处理纳兰家烙毒\", \"以异火与炼药能力换取关键人脉。\", \"soul>=12\", \"reputation:+4\"),\n        (\"赢得炼药师大会\", \"在大会决赛中挫败敌对炼药师。\", \"alchemy>=12\", \"alchemy:+5,reputation:+8\"),\n    ]),\n    _story_phase(\"yunlan_duel\", \"三年之约决战\", \"约定期限已至，你必须登上云岚宗。\", \"击败纳兰嫣然并从宗门追击中脱身。\", \"失败会让三年努力失去意义。\", 8, \"level>=15,flag:three_year_pact=1\", \"flag:rival_resolved=1,flag:yunlan_hostile=1,reputation:+20\", [\n        (\"登上云岚宗\", \"突破宗门压力并抵达决战场。\", \"level>=15\", \"reputation:+5\"),\n        (\"击败纳兰嫣然\", \"兑现三年之约。\", \"flag:three_year_pact=1\", \"rel:npc_nalan_yanran:+20,reputation:+10\"),\n        (\"再上云岚宗击杀云棱\", \"处理萧家遇袭的直接责任人。\", \"reputation>=20\", \"flag:yunleng_defeated=1\"),\n        (\"逃离加玛帝国\", \"在云山追击下保全自己并前往黑角域。\", \"soul>=15\", \"flag:first_yunlan_escape=1\"),\n    ]),\n    _story_phase(\"canaan_outer\", \"迦南学院外院\", \"离开加玛帝国后，你终于前往迦南学院。\", \"完成入院与外院成长，为进入内院做准备。\", \"无法进入内院会错失核心修炼资源。\", 9, \"level>=18\", \"flag:joined_canaan=1,reputation:+8\", [\n        (\"穿越黑角域\", \"通过黑域大平原与拍卖争夺抵达学院。\", \"adventure_points>=10,flag:first_yunlan_escape=1\", \"flag:first_black_corner_crossing=1\"),\n        (\"抵达迦南学院\", \"完成迟到后的入院考验。\", \"level>=18\", \"flag:joined_canaan=1\"),\n        (\"建立新生队伍\", \"与同伴形成可靠的小队。\", \"reputation>=25\", \"reputation:+5\"),\n        (\"通过内院选拔赛\", \"赢得进入内院的资格。\", \"training_wins>=3\", \"flag:entered_inner_academy=1\"),\n    ]),\n    _story_phase(\"canaan_inner\", \"内院磐门与强榜\", \"内院资源竞争激烈，新生必须抱团立足。\", \"建立磐门并在强榜大赛中取得资格。\", \"没有自己的势力将持续受到压制。\", 10, \"flag:entered_inner_academy=1,reputation>=25\", \"flag:pan_gate_founded=1,reputation:+10\", [\n        (\"建立磐门\", \"团结新生并建立稳定据点。\", \"reputation>=25\", \"flag:pan_gate_founded=1\"),\n        (\"结识紫研\", \"通过内院任务与紫研建立信任。\", \"adventure_points>=12\", \"rel:npc_ziyan:+10\"),\n        (\"挑战强榜大赛\", \"取得进入天焚炼气塔核心区域的资格。\", \"training_wins>=4\", \"flag:strong_rank_won=1\"),\n    ]),\n    _story_phase(\"fallen_heart\", \"陨落心炎与天焚炼气塔\", \"天焚炼气塔异动，陨落心炎即将失控。\", \"守住内院并收服陨落心炎。\", \"异火失控会摧毁内院。\", 11, \"level>=25,flag:strong_rank_won=1\", \"item:+item_fallen_heart_flame,douqi:+30\", [\n        (\"调查炼气塔异动\", \"确认陨落心炎暴动征兆。\", \"soul>=20\", \"flag:fallen_heart_unstable=1\"),\n        (\"深入塔底\", \"在封印崩溃前抵达异火本体。\", \"level>=25\", \"exp:+80\"),\n        (\"收服陨落心炎\", \"承受异火炼体并返回内院。\", \"flag:fallen_heart_unstable=1\", \"item:+item_fallen_heart_flame\"),\n    ]),\n    _story_phase(\"black_corner_war\", \"黑角域入侵内院\", \"韩枫联合黑角域势力进攻内院，试图夺走陨落心炎。\", \"守住内院并击退韩枫与黑盟。\", \"学院失守会让异火和盟友落入韩枫手中。\", 12, \"level>=28,flag:pan_gate_founded=1\", \"flag:han_feng_escaped=1,flag:soul_hall_exposed=1,reputation:+15\", [\n        (\"集结学院盟友\", \"组织内院力量抵挡黑盟入侵。\", \"reputation>=35\", \"reputation:+5\"),\n        (\"击退韩枫与黑盟\", \"保住学院并摧毁韩枫肉身。\", \"level>=28\", \"flag:han_feng_hostile=1\"),\n        (\"发现魂殿接应\", \"确认韩枫灵魂被魂殿救走。\", \"soul>=25\", \"flag:han_feng_escaped=1,flag:soul_hall_exposed=1\"),\n    ]),\n    _story_phase(\"yunlan_war\", \"重返加玛与云岚宗大战\", \"父亲失踪、萧家遭难，线索指向云岚宗与魂殿。\", \"救援萧家、击败云山并重建故土秩序。\", \"拖延会让萧家与盟友被逐个击破。\", 13, \"level>=30,flag:first_yunlan_escape=1\", \"flag:yan_alliance_founded=1,reputation:+20\", [\n        (\"追查父亲失踪\", \"确认萧家危机与魂殿介入。\", \"reputation>=35\", \"flag:xiao_family_crisis=1\"),\n        (\"击败云山，药老被掳\", \"终结云岚宗威胁，但魂殿护法趁乱掳走药老。\", \"level>=30,flag:yunlan_hostile=1\", \"flag:yunlan_defeated=1,flag:yao_lao_captured=1\"),\n        (\"建立炎盟\", \"联合加玛帝国盟友保护萧家。\", \"reputation>=45\", \"flag:yan_alliance_founded=1\"),\n    ]),\n    _story_phase(\"poison_sect_war\", \"出云帝国与毒宗之战\", \"炎盟刚刚建立，毒宗、金雁宗与慕兰谷便入侵加玛帝国。\", \"守住炎盟、重逢小医仙并解决厄难毒体危机。\", \"联盟初战失败会让故土再次陷入战乱。\", 14, \"level>=33,flag:yan_alliance_founded=1\", \"flag:northwest_stabilized=1,rel:npc_xiao_yixian:+15,reputation:+15\", [\n        (\"守卫加玛帝国\", \"带领炎盟击退三宗联军。\", \"reputation>=50\", \"flag:yan_alliance_defended=1\"),\n        (\"重逢毒宗宗主\", \"确认小医仙身份并避免双方死战。\", \"rel:npc_xiao_yixian>=40\", \"rel:npc_xiao_yixian:+10\"),\n        (\"暂时封印厄难毒体\", \"寻找毒丹之法，暂时压制小医仙的毒体。\", \"alchemy>=20,flag:poison_companion=1\", \"flag:poison_body_sealed=1\"),\n    ]),\n    _story_phase(\"return_black_corner\", \"重返黑角域\", \"魂殿线索与韩枫逃亡方向都指向黑角域。\", \"清算魔炎谷、擒获韩枫并取得魂殿情报。\", \"缺少情报便无法定位药老。\", 15, \"level>=35,flag:han_feng_escaped=1\", \"flag:han_feng_captured=1,flag:mentor_prison_known=1,reputation:+15\", [\n        (\"清算魔炎谷\", \"摧毁黑角域中敌对势力的核心据点。\", \"reputation>=55\", \"flag:demon_flame_valley_defeated=1\"),\n        (\"擒获韩枫灵魂\", \"击败韩枫与魂殿接应者。\", \"level>=35,flag:han_feng_escaped=1\", \"flag:han_feng_captured=1\"),\n        (\"取得药老关押情报\", \"从韩枫与魂殿护法处取得关键线索。\", \"soul>=30\", \"flag:mentor_prison_known=1\"),\n    ]),\n    _story_phase(\"revisit_tower\", \"再探天焚炼气塔\", \"黑角域清算后，炼气塔底的岩浆世界仍隐藏着异火和古帝线索。\", \"再入塔底、救出天火尊者并发现古帝洞府线索。\", \"忽略塔底秘密会让终局线索断裂。\", 16, \"level>=36,flag:han_feng_captured=1\", \"flag:ancient_emperor_clue_found=1,reputation:+8\", [\n        (\"返回迦南学院\", \"安置萧门与磐门并准备再入塔底。\", \"reputation>=58\", \"reputation:+3\"),\n        (\"救出天火尊者\", \"深入岩浆世界并帮助残魂脱困。\", \"soul>=32\", \"flag:tianhuo_rescued=1\"),\n        (\"发现古帝玉线索\", \"确认岩浆世界与古帝洞府存在联系。\", \"flag:tianhuo_rescued=1\", \"flag:ancient_emperor_clue_found=1\"),\n    ]),\n    _story_phase(\"zhongzhou_arrival\", \"进入中州\", \"药老被魂殿掳走，新的线索指向强者云集的中州。\", \"在中州立足、寻找星陨阁并追查魂殿。\", \"没有据点与情报便无法展开营救。\", 16, \"level>=36,flag:mentor_prison_known=1\", \"flag:star_pavilion_found=1,reputation:+15\", [\n        (\"穿越空间虫洞\", \"抵达中州并适应新的强敌环境。\", \"level>=35\", \"exp:+100\"),\n        (\"四方阁立威\", \"通过风雷阁冲突建立中州声望。\", \"training_wins>=5\", \"reputation:+10\"),\n        (\"找到风尊者与星陨阁\", \"联系药老旧友并建立营救据点。\", \"reputation>=50\", \"flag:star_pavilion_found=1,rel:npc_feng_zunzhe:+15\"),\n    ]),\n    _story_phase(\"ye_ice_valley\", \"叶城与冰河谷\", \"中州丹塔选拔将近，小医仙的厄难毒体也引来冰河谷追杀。\", \"帮助叶家取得资格，并彻底解决厄难毒体。\", \"毒体失控会危及小医仙与周围所有人。\", 17, \"level>=38,flag:poison_body_sealed=1\", \"flag:poison_body_resolved=1,reputation:+12\", [\n        (\"帮助叶家通过考核\", \"取得参加丹会的正式资格。\", \"alchemy>=28\", \"flag:dan_meeting_qualified=1\"),\n        (\"迎战冰河谷\", \"保护小医仙并击退冰河谷追兵。\", \"level>=38,rel:npc_xiao_yixian>=50\", \"reputation:+5\"),\n        (\"凝聚毒丹\", \"彻底控制厄难毒体而非继续封印。\", \"alchemy>=30,flag:poison_body_sealed=1\", \"flag:poison_body_resolved=1\"),\n    ]),\n    _story_phase(\"dan_meeting_flame\", \"丹会与三千焱炎火\", \"丹塔大会能提供声望、盟友与接近三千焱炎火的机会。\", \"赢得丹会并收服星域异火。\", \"失败会失去营救药老的重要支援。\", 18, \"level>=40,alchemy>=30,soul>=30,flag:dan_meeting_qualified=1\", \"item:+item_three_thousand_flame,alchemy:+15,reputation:+20\", [\n        (\"通过丹会选拔\", \"证明炼药与灵魂能力。\", \"alchemy>=30,soul>=30\", \"reputation:+10\"),\n        (\"赢得丹会\", \"在顶尖炼药师竞争中夺得名次。\", \"alchemy>=35\", \"flag:dan_meeting_won=1\"),\n        (\"进入星域收服异火\", \"处理魂殿干扰并取得三千焱炎火。\", \"level>=40,flag:dan_meeting_won=1\", \"item:+item_three_thousand_flame\"),\n    ]),\n    _story_phase(\"save_mentor\", \"营救药老\", \"魂殿囚禁着药老，营救时机终于成熟。\", \"突袭亡魂山脉并救回药老灵魂。\", \"失败将失去导师和对抗魂殿的核心盟友。\", 19, \"level>=45,flag:star_pavilion_found=1,rel:npc_yao_lao>=60\", \"flag:yao_lao_rescued=1,rel:npc_yao_lao:+20,reputation:+20\", [\n        (\"突袭魂殿分殿\", \"依靠丹塔与星陨阁情报展开营救。\", \"reputation>=60\", \"flag:yao_lao_rescued=1\"),\n        (\"撤回星陨阁\", \"保护重伤的药老灵魂撤离。\", \"soul>=40,flag:yao_lao_rescued=1\", \"flag:mentor_soul_secured=1\"),\n        (\"准备复活材料\", \"确认重塑躯体仍缺少斗圣骸骨。\", \"alchemy>=40\", \"flag:saint_bones_needed=1\"),\n    ]),\n    _story_phase(\"ancient_ruins\", \"远古遗迹\", \"远古遗迹现世，其中的斗圣骸骨是复活药老的关键。\", \"探索遗迹、取得龙凰本源果与斗圣骸骨。\", \"无法取得骸骨便不能为药老重塑躯体。\", 20, \"level>=48,soul>=35,flag:saint_bones_needed=1\", \"item:+item_earth_skill,flag:saint_bones_acquired=1,soul:+10\", [\n        (\"定位遗迹入口\", \"识别空间波动并准备探索队伍。\", \"soul>=35\", \"exp:+50\"),\n        (\"重逢青鳞\", \"在遗迹中与青鳞会合并应对远古天蛇力量。\", \"rel:npc_qing_lin>=35\", \"rel:npc_qing_lin:+10\"),\n        (\"取得龙凰本源果\", \"为紫研后续的龙皇血脉觉醒准备机缘。\", \"level>=48\", \"flag:dragon_phoenix_fruit_acquired=1\"),\n        (\"夺取斗圣骸骨\", \"击退争夺者并带回重塑躯体的核心材料。\", \"reputation>=70\", \"item:+item_earth_skill,flag:saint_bones_acquired=1\"),\n    ]),\n    _story_phase(\"revive_mentor\", \"复活药老与重建星陨阁\", \"斗圣骸骨已经到手，可以为药老重塑躯体。\", \"复活药老并将星陨阁建设为长期据点。\", \"拖延会让魂殿再次找到虚弱的药老。\", 21, \"alchemy>=42,flag:saint_bones_acquired=1,flag:mentor_soul_secured=1\", \"flag:yao_lao_revived=1,flag:star_pavilion_rebuilt=1,reputation:+20\", [\n        (\"炼制斗圣躯体\", \"使用斗圣骸骨与异火完成躯体炼制。\", \"alchemy>=42,flag:saint_bones_acquired=1\", \"flag:saint_body_refined=1\"),\n        (\"药老复活\", \"让药老灵魂与新躯体完成融合。\", \"soul>=45,flag:saint_body_refined=1\", \"flag:yao_lao_revived=1,rel:npc_yao_lao:+15\"),\n        (\"重建星陨阁\", \"将临时营救据点发展为长期势力。\", \"reputation>=75\", \"flag:star_pavilion_rebuilt=1\"),\n    ]),\n    _story_phase(\"flower_sect\", \"花宗与云韵传承\", \"花宗传承纷争将云韵卷入危机，也影响中州盟友格局。\", \"帮助云韵取得花宗传承并争取花宗支持。\", \"花宗落入敌对势力会削弱未来联盟。\", 22, \"level>=50,flag:star_pavilion_rebuilt=1\", \"flag:flower_sect_allied=1,rel:npc_yun_yun:+15,reputation:+10\", [\n        (\"赶往花宗\", \"响应云韵求援并查明宗主传承争议。\", \"reputation>=75\", \"rel:npc_yun_yun:+5\"),\n        (\"击败花宗敌手\", \"保护云韵完成传承。\", \"level>=50\", \"exp:+120\"),\n        (\"争取花宗支持\", \"让花宗成为星陨阁的盟友。\", \"rel:npc_yun_yun>=30\", \"flag:flower_sect_allied=1\"),\n    ]),\n    _story_phase(\"dragon_island_legacy\", \"龙岛与龙皇血脉\", \"龙凰本源果被送往分裂的古龙岛，紫研需要完成血脉觉醒。\", \"帮助紫研觉醒龙皇血脉并稳住东龙岛。\", \"紫研失败会让太虚古龙族继续分裂。\", 23, \"level>=50,rel:npc_ziyan>=35,flag:dragon_phoenix_fruit_acquired=1\", \"flag:dragon_emperor_awakened=1,rel:npc_ziyan:+15,reputation:+10\", [\n        (\"抵达东龙岛\", \"穿越虚空并确认古龙族分裂局势。\", \"soul>=40\", \"flag:east_dragon_island_reached=1\"),\n        (\"守护龙凰晶层\", \"在三岛压力下保护紫研完成炼化。\", \"level>=50\", \"rel:npc_ziyan:+10\"),\n        (\"见证龙皇觉醒\", \"帮助紫研继承龙皇血脉。\", \"rel:npc_ziyan>=40\", \"flag:dragon_emperor_awakened=1\"),\n    ]),\n    _story_phase(\"gu_clan_tomb\", \"古族成人礼与天墓\", \"古族成人礼与天墓开启提供了接触萧族先祖的机会。\", \"赢得古族认可并获得萧玄传承。\", \"失败会削弱古族联盟与血脉成长。\", 24, \"level>=52,rel:npc_xun_er>=60\", \"rel:npc_gu_yuan:+20,douqi:+50\", [\n        (\"参加古族成人礼\", \"在远古种族面前证明实力。\", \"reputation>=75\", \"rel:npc_gu_yuan:+10\"),\n        (\"进入天墓\", \"与同伴穿越能量风暴。\", \"level>=50\", \"exp:+150\"),\n        (\"接受萧玄传承\", \"恢复萧族血脉并理解先祖使命。\", \"soul>=45\", \"flag:xiao_bloodline_awakened=1,douqi:+30\"),\n    ]),\n    _story_phase(\"northwest_fortress_war\", \"玄黄要塞与西北大陆大战\", \"魂殿联军进攻西北大陆，炎盟与萧家在玄黄要塞陷入苦战。\", \"返回故土、守住要塞并稳定西北联盟。\", \"故土失守会让天府联盟失去根基。\", 25, \"level>=54,flag:yan_alliance_founded=1\", \"flag:northwest_front_secured=1,reputation:+18\", [\n        (\"赶回玄黄要塞\", \"响应炎盟求援并集结故土盟友。\", \"reputation>=82\", \"flag:northwest_reinforced=1\"),\n        (\"守卫萧家与炎盟\", \"击退魂殿联军对西北大陆的进攻。\", \"level>=54\", \"reputation:+10\"),\n        (\"稳定西北战线\", \"重新整合加玛、出云与蛇人族力量。\", \"flag:northwest_stabilized=1\", \"flag:northwest_front_secured=1\"),\n    ]),\n    _story_phase(\"bodhi_tree\", \"莽荒古域与菩提古树\", \"菩提古树现世，进入莽荒古域还需面对兽潮与各方争夺。\", \"穿越莽荒古域、突破幻境并取得菩提心。\", \"心境不足会永远迷失。\", 25, \"level>=55,soul>=45\", \"item:+item_bodhi_heart,item:+item_bodhi_seed,soul:+20\", [\n        (\"穿越莽荒古域兽潮\", \"与盟友突破古域入口和兽潮阻拦。\", \"reputation>=80\", \"exp:+100\"),\n        (\"争夺古树入口\", \"与各方势力竞争进入资格。\", \"reputation>=80\", \"exp:+100\"),\n        (\"突破菩提幻境\", \"分辨幻象并保持自我。\", \"soul>=45\", \"soul:+10\"),\n        (\"取得菩提心\", \"吸收古树核心机缘并完成境界突破。\", \"level>=55\", \"item:+item_bodhi_heart,item:+item_bodhi_seed\"),\n    ]),\n    _story_phase(\"tianfu_alliance\", \"建立天府联盟\", \"魂殿全面施压，单一势力已无法抵抗。\", \"联合星陨阁、丹塔、炎盟与伙伴势力。\", \"联盟失败会让各方被逐个击破。\", 26, \"flag:star_pavilion_rebuilt=1,flag:yan_alliance_founded=1,reputation>=90\", \"flag:tianfu_alliance_founded=1,reputation:+20\", [\n        (\"调查灵族消失\", \"确认远古种族正在遭受魂族秘密袭击。\", \"soul>=50\", \"flag:ancient_clan_disappearances=1\"),\n        (\"整合星陨阁与炎盟\", \"统一两地情报与资源网络。\", \"reputation>=90\", \"reputation:+5\"),\n        (\"争取丹塔与伙伴势力\", \"让中州盟友加入共同防线。\", \"alchemy>=45,rel:npc_ziyan>=35\", \"reputation:+10\"),\n        (\"建立天府联盟\", \"形成能够正面对抗魂殿的联盟。\", \"flag:star_pavilion_rebuilt=1\", \"flag:tianfu_alliance_founded=1\"),\n    ]),\n    _story_phase(\"nether_spring\", \"九幽黄泉与妖暝\", \"建立天府联盟后，需要争取九幽地冥蟒族并强化彩鳞血脉。\", \"救出妖暝、取得妖圣精血并争取魔兽盟友。\", \"缺少魔兽盟友会让联盟侧翼空虚。\", 27, \"level>=58,flag:tianfu_alliance_founded=1\", \"flag:nether_python_allied=1,rel:npc_cai_lin:+15,reputation:+10\", [\n        (\"深入九幽黄泉\", \"帮助彩鳞寻找血脉突破机缘。\", \"rel:npc_cai_lin>=20\", \"rel:npc_cai_lin:+10\"),\n        (\"救出妖暝\", \"推翻九幽地冥蟒族中的篡位者。\", \"level>=58\", \"flag:yaoming_restored=1\"),\n        (\"争取魔兽盟友\", \"让九幽地冥蟒族加入天府联盟。\", \"flag:yaoming_restored=1\", \"flag:nether_python_allied=1\"),\n    ]),\n    _story_phase(\"dragon_island_war\", \"古龙岛三岛大战\", \"三大龙王拒绝承认紫研，古龙族战争爆发。\", \"帮助紫研击败三岛联军，但北龙王趁乱逃脱。\", \"北龙王仍会成为后续隐患。\", 28, \"level>=60,flag:dragon_emperor_awakened=1\", \"flag:north_dragon_escaped=1,rel:npc_ziyan:+15,reputation:+15\", [\n        (\"重返古龙岛\", \"响应紫研求援并集结东龙岛力量。\", \"rel:npc_ziyan>=45\", \"reputation:+5\"),\n        (\"迎战三大龙王\", \"打破三岛联军并保护紫研。\", \"level>=60\", \"exp:+200\"),\n        (\"北龙王逃脱\", \"结束三岛大战并追踪北龙王去向。\", \"flag:dragon_emperor_awakened=1\", \"flag:north_dragon_escaped=1\"),\n    ]),\n    _story_phase(\"soul_hall_war\", \"血洗魂殿人殿\", \"天府联盟成立后，双方开始争夺中州主动权。\", \"摧毁魂殿核心分殿并夺回灵魂本源。\", \"若魂殿仍掌握灵魂本源，联盟将持续受制。\", 29, \"level>=62,flag:tianfu_alliance_founded=1\", \"flag:soul_hall_weakened=1,soul:+15,reputation:+20\", [\n        (\"血洗魂殿人殿\", \"摧毁魂殿灵魂收集据点。\", \"reputation>=105\", \"flag:soul_hall_core_exposed=1\"),\n        (\"夺回灵魂本源\", \"释放被囚灵魂并强化自身灵魂境界。\", \"soul>=55,flag:soul_hall_core_exposed=1\", \"soul:+15\"),\n        (\"逼退魂殿殿主\", \"迫使魂殿收缩，但殿主仍未被彻底击败。\", \"level>=62\", \"flag:soul_hall_weakened=1\"),\n    ]),\n    _story_phase(\"demon_flame\", \"净莲妖火\", \"残图汇聚，净莲妖火空间开启。\", \"突破妖火幻境并完成收服。\", \"失败会被妖火控制。\", 30, \"level>=64,soul>=55,flag:soul_hall_weakened=1\", \"item:+item_purifying_demon_flame,douqi:+80\", [\n        (\"集齐妖火残图\", \"借助联盟情报定位妖火空间。\", \"soul>=50\", \"flag:demon_flame_map=1\"),\n        (\"突破妖火幻境\", \"抵抗净莲妖圣留下的幻境。\", \"soul>=55\", \"soul:+10\"),\n        (\"收服净莲妖火\", \"与盟友共同压制妖火本体。\", \"level>=60\", \"item:+item_purifying_demon_flame\"),\n    ]),\n    _story_phase(\"post_demon_wars\", \"魂殿殿主与北龙王终战\", \"净莲妖火之后，魂殿殿主与逃亡的北龙王先后发动反扑。\", \"击败两名强敌并完成古龙族统一。\", \"残余强敌会破坏大陆联盟。\", 31, \"level>=66,flag:north_dragon_escaped=1,flag:soul_hall_weakened=1\", \"flag:soul_hall_defeated=1,flag:dragon_clan_unified=1,reputation:+20\", [\n        (\"击败魂殿殿主\", \"终结魂殿在中州的公开统治。\", \"level>=66,flag:soul_hall_weakened=1\", \"flag:soul_hall_defeated=1\"),\n        (\"追击北龙王\", \"阻止北龙王利用化龙魔阵反扑。\", \"rel:npc_ziyan>=50,flag:north_dragon_escaped=1\", \"exp:+200\"),\n        (\"统一太虚古龙族\", \"彻底结束古龙族分裂。\", \"flag:north_dragon_escaped=1\", \"flag:dragon_clan_unified=1\"),\n    ]),\n    _story_phase(\"medicine_ceremony\", \"药典与药族灭族战\", \"药族举办药典，魂族随后发动灭族袭击。\", \"通过药典、救援药族幸存者并确认魂族计划。\", \"药族覆灭会让魂族夺得更多血脉与帝玉。\", 32, \"alchemy>=50,soul>=55\", \"alchemy:+20,flag:medicine_clan_survivors_saved=1,reputation:+20\", [\n        (\"完成药典考验\", \"展现高阶炼药与灵魂控制。\", \"alchemy>=50,soul>=55\", \"alchemy:+10\"),\n        (\"应对药族灭族战\", \"在魂族袭击中保护药族幸存者。\", \"level>=65\", \"flag:hun_clan_hostile=1\"),\n        (\"救出药族幸存者\", \"将幸存力量带回联盟并保存药族传承。\", \"reputation>=110\", \"flag:medicine_clan_survivors_saved=1\"),\n    ]),\n    _story_phase(\"ancient_clan_war\", \"远古种族联盟战\", \"魂族开始夺取各族帝玉，远古种族面临覆灭。\", \"协调古族、古龙族与盟友，并救回被囚的父亲。\", \"联盟破裂会让魂族打开古帝洞府。\", 33, \"flag:dragon_clan_unified=1,flag:hun_clan_hostile=1\", \"flag:ancient_alliance=1,rel:npc_xiao_zhan:+20,reputation:+25\", [\n        (\"确认魂族夺玉计划\", \"整合药族幸存者与古族情报。\", \"flag:medicine_clan_survivors_saved=1\", \"flag:emperor_jade_crisis=1\"),\n        (\"再入天墓\", \"借助萧玄残魂将灵魂境界提升至帝境。\", \"flag:xiao_bloodline_awakened=1,soul>=65\", \"flag:emperor_soul_awakened=1,soul:+20\"),\n        (\"营救萧战\", \"在魂族大战中救回被囚多年的父亲。\", \"flag:xiao_family_crisis=1,level>=68\", \"flag:xiao_zhan_rescued=1,rel:npc_xiao_zhan:+20\"),\n        (\"协调远古种族盟友\", \"争取古族与统一后的太虚古龙族共同作战。\", \"rel:npc_gu_yuan>=30,flag:dragon_clan_unified=1\", \"flag:ancient_alliance=1\"),\n    ]),\n    _story_phase(\"ancient_emperor\", \"古帝洞府\", \"魂族打开古帝洞府，成帝传承成为最后争夺。\", \"进入洞府并阻止魂族独占传承。\", \"失败会让魂天帝完成最终突破。\", 34, \"level>=70,flag:ancient_alliance=1\", \"flag:ancient_emperor_jade=1,item:+item_tuoshe_jade,douqi:+100\", [\n        (\"追入古帝洞府\", \"集结联盟进入洞府空间。\", \"flag:ancient_alliance=1\", \"flag:ancient_emperor_jade=1\"),\n        (\"争夺帝品雏丹\", \"阻止魂族夺取成帝关键。\", \"level>=70\", \"douqi:+50\"),\n        (\"魂天帝夺丹成帝\", \"在争夺失败后应对魂天帝完成突破的危机。\", \"level>=72\", \"flag:soul_emperor_ascended=1\"),\n        (\"接受古帝传承\", \"获得迎战魂天帝的最后力量。\", \"flag:emperor_soul_awakened=1\", \"flag:emperor_legacy=1,douqi:+100\"),\n    ]),\n    _story_phase(\"final_war\", \"双帝之战\", \"魂天帝突破，大陆已无退路。\", \"集结联军并完成最终决战。\", \"失败意味着大陆秩序覆灭。\", 35, \"level>=80,flag:emperor_legacy=1\", \"flag:soul_emperor_defeated=1,reputation:+100\", [\n        (\"集结大陆联军\", \"让所有盟友进入最终战场。\", \"reputation>=120,flag:ancient_alliance=1\", \"reputation:+20\"),\n        (\"突破斗帝\", \"以古帝传承与异火完成最终突破。\", \"level>=80,flag:emperor_legacy=1\", \"flag:xiao_emperor_awakened=1\"),\n        (\"迎战魂天帝\", \"封印魂天帝并终结魂族战争。\", \"flag:xiao_emperor_awakened=1\", \"flag:soul_emperor_defeated=1\"),\n    ]),\n    _story_phase(\"five_emperors\", \"五帝破空\", \"大战结束后，大陆恢复秩序，新的世界通道出现。\", \"安置盟友、留下传承并开启新纪元。\", \"若没有完成战后安排，胜利仍会留下隐患。\", 36, \"flag:soul_emperor_defeated=1\", \"flag:story_finished=1,item:+item_emperor_flame\", [\n        (\"重建大陆秩序\", \"处理战后势力与家族安置。\", \"reputation>=150\", \"reputation:+20\"),\n        (\"留下斗帝传承\", \"让新的修炼道路延续。\", \"flag:xiao_emperor_awakened=1\", \"item:+item_emperor_flame\"),\n        (\"五帝破空\", \"与重要伙伴前往新的世界。\", \"flag:ancient_alliance=1\", \"flag:story_finished=1\"),\n    ]),\n]\n\n\n# 工作簿里程碑必须映射到真实节点，并按实际剧情先后排列。\nPLOT_MILESTONE_SEQUENCE = [\n    \"退婚\", \"三年之约\", \"青莲地心火争夺\", \"炼药师大会\", \"内院选拔赛\",\n    \"强榜大赛\", \"陨落心炎与天焚炼气塔\", \"黑角域大战\", \"云岚宗大战\",\n    \"丹会\", \"三千焱炎火\", \"营救药老\", \"远古遗迹\", \"古族成人礼\",\n    \"天墓与萧玄\", \"菩提古树\", \"净莲妖火\", \"药典\", \"古帝洞府\",\n    \"双帝之战\", \"五帝破空\",\n]\n\nPLOT_MILESTONE_COVERAGE = {\n    \"退婚\": (\"退婚与三年之约\", \"应对退婚\"),\n    \"三年之约\": (\"退婚与三年之约\", \"立下三年之约\"),\n    \"青莲地心火争夺\": (\"塔戈尔沙漠与青莲地心火\", \"美杜莎神殿争夺\"),\n    \"炼药师大会\": (\"炼药师大会\", \"赢得炼药师大会\"),\n    \"内院选拔赛\": (\"迦南学院外院\", \"通过内院选拔赛\"),\n    \"强榜大赛\": (\"内院磐门与强榜\", \"挑战强榜大赛\"),\n    \"陨落心炎与天焚炼气塔\": (\"陨落心炎与